{# Gallery carousel + lightbox #}
{% if mb.gallery and mb.gallery.length %}
<script>
(function initLpMbGallery() {
  function enableHorizontalDrag(viewport) {
    if (!viewport) return;
    var isDown = false, startX = 0, startScroll = 0, moved = false;
    viewport.addEventListener("pointerdown", function(e) {
      if (e.pointerType === "touch") return;
      isDown = true; moved = false; startX = e.clientX; startScroll = viewport.scrollLeft;
      viewport.classList.add("is-dragging");
      try { viewport.setPointerCapture(e.pointerId); } catch(err) {}
    });
    viewport.addEventListener("pointermove", function(e) {
      if (!isDown) return;
      var dx = e.clientX - startX;
      if (Math.abs(dx) > 4) moved = true;
      viewport.scrollLeft = startScroll - dx;
    });
    function end(e) {
      if (!isDown) return; isDown = false;
      viewport.classList.remove("is-dragging");
      if (e && e.pointerId != null) { try { viewport.releasePointerCapture(e.pointerId); } catch(err) {} }
    }
    viewport.addEventListener("pointerup", end);
    viewport.addEventListener("pointercancel", end);
    viewport.addEventListener("pointerleave", end);
    viewport.addEventListener("click", function(e) { if (moved) { e.preventDefault(); e.stopPropagation(); moved = false; } }, true);
    viewport.addEventListener("dragstart", function(e) { e.preventDefault(); });
  }

  var wrap = document.querySelector("[data-lp-mb-bubbles-wrap]");
  if (wrap) {
    var strip = wrap.querySelector("[data-lp-mb-bubbles]");
    var prevBtn = wrap.querySelector("[data-lp-mb-prev]");
    var nextBtn = wrap.querySelector("[data-lp-mb-next]");
    if (strip) {
      function cardWidth() {
        var card = strip.querySelector(".mb-bubble");
        if (!card) return strip.clientWidth * 0.8;
        var cs = getComputedStyle(strip);
        var gap = parseFloat(cs.columnGap || cs.gap || "0") || 0;
        return card.getBoundingClientRect().width + gap;
      }
      function updateArrows() {
        var max = strip.scrollWidth - strip.clientWidth;
        if (prevBtn) prevBtn.toggleAttribute("disabled", strip.scrollLeft <= 2);
        if (nextBtn) nextBtn.toggleAttribute("disabled", strip.scrollLeft >= max - 2);
      }
      if (prevBtn) prevBtn.addEventListener("click", function() { strip.scrollBy({ left: -cardWidth(), behavior: "smooth" }); });
      if (nextBtn) nextBtn.addEventListener("click", function() { strip.scrollBy({ left: cardWidth(), behavior: "smooth" }); });
      strip.addEventListener("scroll", updateArrows, { passive: true });
      window.addEventListener("resize", updateArrows);
      updateArrows();
      if (window.matchMedia("(max-width: 767px)").matches) enableHorizontalDrag(strip);
    }
  }

  var galleryModal = document.getElementById("lp-mb-gallery-modal");
  if (!galleryModal) return;
  var galleryImage = galleryModal.querySelector("[data-lp-mb-gallery-image]");
  var galleryVideo = galleryModal.querySelector("[data-lp-mb-gallery-video]");
  var galleryStage = galleryModal.querySelector("[data-lp-mb-gallery-stage]");
  var galleryItems = Array.prototype.slice.call(document.querySelectorAll("[data-lp-mb-gallery-item]"));
  var galleryTriggers = Array.prototype.slice.call(document.querySelectorAll("[data-lp-mb-gallery-trigger]"));
  var closeGalleryBtns = galleryModal.querySelectorAll("[data-lp-mb-gallery-close]");
  var prevGalleryBtn = galleryModal.querySelector("[data-lp-mb-gallery-prev]");
  var nextGalleryBtn = galleryModal.querySelector("[data-lp-mb-gallery-next]");
  var galleryIndex = 0;

  function pauseModalVideo() {
    if (!galleryVideo) return;
    galleryVideo.pause(); galleryVideo.src = "";
    try { galleryVideo.load(); } catch(err) {}
  }
  function renderGalleryImage() {
    if (!galleryItems.length) return;
    var source = galleryItems[galleryIndex];
    var isVideo = source.tagName === "VIDEO";
    if (isVideo) {
      if (galleryImage) { galleryImage.src = ""; galleryImage.style.display = "none"; }
      if (galleryVideo) {
        galleryVideo.src = source.currentSrc || source.getAttribute("src") || "";
        galleryVideo.style.display = "block"; galleryVideo.muted = false;
        try { galleryVideo.play(); } catch(err) {}
      }
    } else {
      pauseModalVideo();
      if (galleryVideo) galleryVideo.style.display = "none";
      if (galleryImage) { galleryImage.style.display = "block"; galleryImage.src = source.currentSrc || source.src; galleryImage.alt = source.alt || ""; }
    }
  }
  function openGallery(index) {
    galleryIndex = Math.max(0, Math.min(index, galleryItems.length - 1));
    renderGalleryImage();
    galleryModal.hidden = false;
    galleryModal.setAttribute("aria-hidden", "false");
    document.body.classList.add("modal-open");
  }
  function closeGallery() {
    pauseModalVideo();
    if (galleryVideo) galleryVideo.style.display = "none";
    if (galleryImage) { galleryImage.style.display = "none"; galleryImage.src = ""; }
    galleryModal.hidden = true;
    galleryModal.setAttribute("aria-hidden", "true");
    document.body.classList.remove("modal-open");
  }
  function nextImage() { if (!galleryItems.length) return; galleryIndex = (galleryIndex + 1) % galleryItems.length; renderGalleryImage(); }
  function prevImage() { if (!galleryItems.length) return; galleryIndex = (galleryIndex - 1 + galleryItems.length) % galleryItems.length; renderGalleryImage(); }

  galleryTriggers.forEach(function(item) {
    item.addEventListener("click", function(e) {
      var idx = Number(e.currentTarget.getAttribute("data-lp-mb-gallery-index"));
      openGallery(isFinite(idx) ? idx : 0);
    });
  });
  closeGalleryBtns.forEach(function(btn) { btn.addEventListener("click", closeGallery); });
  if (nextGalleryBtn) nextGalleryBtn.addEventListener("click", nextImage);
  if (prevGalleryBtn) prevGalleryBtn.addEventListener("click", prevImage);

  var swipeStartX = null;
  if (galleryStage) {
    galleryStage.addEventListener("touchstart", function(e) {
      if (e.touches && e.touches.length) swipeStartX = e.touches[0].clientX;
    }, { passive: true });
    galleryStage.addEventListener("touchend", function(e) {
      if (swipeStartX === null || !e.changedTouches || !e.changedTouches.length) return;
      var dx = e.changedTouches[0].clientX - swipeStartX; swipeStartX = null;
      if (Math.abs(dx) < 40) return;
      if (dx < 0) nextImage(); else prevImage();
    });
  }
  document.addEventListener("keydown", function(e) {
    if (galleryModal.hidden) return;
    if (e.key === "Escape") closeGallery();
    if (e.key === "ArrowRight") nextImage();
    if (e.key === "ArrowLeft") prevImage();
  });
})();
</script>
{% endif %}

{# Process steps drag on mobile #}
<script>
document.addEventListener("DOMContentLoaded", function() {
  document.querySelectorAll("[data-lp-procedure-steps]").forEach(function(root) {
    var viewport = root.querySelector("[data-lp-procedure-steps-viewport]");
    if (!viewport || !window.matchMedia("(max-width: 1023px)").matches) return;
    var isDown = false, startX, scrollLeft;
    viewport.addEventListener("mousedown", function(e) { isDown = true; viewport.classList.add("is-dragging"); startX = e.pageX - viewport.offsetLeft; scrollLeft = viewport.scrollLeft; });
    viewport.addEventListener("mouseleave", function() { isDown = false; viewport.classList.remove("is-dragging"); });
    viewport.addEventListener("mouseup", function() { isDown = false; viewport.classList.remove("is-dragging"); });
    viewport.addEventListener("mousemove", function(e) {
      if (!isDown) return; e.preventDefault();
      viewport.scrollLeft = scrollLeft - (e.pageX - viewport.offsetLeft - startX) * 2;
    });
  });
});
</script>

{# FAQ accordion #}
<script>
(function() {
  var root = document.querySelector("[data-lp-faq-accordion]");
  if (!root) return;
  var panels = root.querySelectorAll(".faq-details");
  panels.forEach(function(panel) {
    panel.addEventListener("toggle", function() {
      if (!panel.open) return;
      panels.forEach(function(other) { if (other !== panel) other.removeAttribute("open"); });
    });
  });
})();
</script>
