              <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
            </div>
            <p class="testimonial-card__quote">{{ item.quote }}</p>
            <button
              type="button"
              class="testimonial-card__expand"
              hidden
              data-testimonial-open
              data-testimonial-index="{{ loop.index0 }}"
            >
              Виж целия отзив
            </button>
            <p class="testimonial-card__name">– {{ item.name }}</p>
          </article>
          {% endfor %}
        </div>
      </div>
    </div>
  </section>

  <script>
    window.ValetoTestimonialsData = {{ mbTestimonials | dump | safe }};
  </script>
  <script src="{{ '/assets/js/testimonials-strip.js' | url }}"></script>
  {% endif %}


  {# ═══════════════════════════════════════════════
     8. FAQ
  ═══════════════════════════════════════════════ #}
  <section
    id="lp-faq"
    class="mb-section section-padding bg-white/70"
    aria-labelledby="lp-faq-heading"
  >
    <div class="container-custom">
      <header class="mb-header mx-auto mb-8 text-center md:mb-10">
        <span class="mb-eyebrow justify-center" data-i18n="pages.mikrobleiding.faq.eyebrow">Въпроси и отговори</span>
        <h2 id="lp-faq-heading" class="mb-title mt-2 text-center" data-i18n="pages.mikrobleiding.faq.title">
          Често задавани въпроси
        </h2>
      </header>

      <div class="faq-stack w-full" data-lp-faq-accordion>

        <details class="faq-details" name="lp-faq">
          <summary class="faq-details__summary">
            <span class="faq-details__question" data-i18n="pages.mikrobleiding.faq.items.0.question">Болезнена ли е процедурата?</span>
            <span class="faq-details__chevron" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="faq-details__chevron-svg"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </summary>
          <div class="faq-details__content"><div class="faq-details__inner">
            <p class="faq-details__answer" data-i18n="pages.mikrobleiding.faq.items.0.answer">Нивото на дискомфорт варира, но повечето клиенти описват усещането като леко одраскване. Използвам локална упойка, така че самата процедура е много по-поносима от очакваното. Голяма част от клиентите се отпускат и дори се засмиват по средата.</p>
          </div></div>
        </details>

        <details class="faq-details" name="lp-faq">
          <summary class="faq-details__summary">
            <span class="faq-details__question" data-i18n="pages.mikrobleiding.faq.items.1.question">Колко дълго издържа микроблейдингът?</span>
            <span class="faq-details__chevron" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="faq-details__chevron-svg"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </summary>
          <div class="faq-details__content"><div class="faq-details__inner">
            <p class="faq-details__answer" data-i18n="pages.mikrobleiding.faq.items.1.answer">Резултатите издържат средно 12 до 18 месеца, в зависимост от типа кожа и начина на живот. За оптимален ефект се прави ретуш около 40–90 дни след първата процедура, а след това — веднъж годишно при нужда.</p>
          </div></div>
        </details>

        <details class="faq-details" name="lp-faq">
          <summary class="faq-details__summary">
            <span class="faq-details__question" data-i18n="pages.mikrobleiding.faq.items.2.question">Как изглеждат веждите веднага след процедурата?</span>
            <span class="faq-details__chevron" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="faq-details__chevron-svg"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </summary>
          <div class="faq-details__content"><div class="faq-details__inner">
            <p class="faq-details__answer" data-i18n="pages.mikrobleiding.faq.items.2.answer">Веднага след процедурата веждите изглеждат по-тъмни и по-наситени. В рамките на 7–14 дни цветът избледнява с около 30–40% и достига своя естествен финален тон. Важно е да спазваш насоките за грижа в периода на заздравяване.</p>
          </div></div>
        </details>

        <details class="faq-details" name="lp-faq">
          <summary class="faq-details__summary">
            <span class="faq-details__question" data-i18n="pages.mikrobleiding.faq.items.3.question">Каква е грижата след процедурата?</span>
            <span class="faq-details__chevron" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="faq-details__chevron-svg"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </summary>
          <div class="faq-details__content"><div class="faq-details__inner">
            <p class="faq-details__answer" data-i18n="pages.mikrobleiding.faq.items.3.answer">Около 7–10 дни след процедурата е важно да избягваш пряко слънце, сауна, басейн и интензивни физически усилия. Ще получиш детайлни писмени насоки за грижа, за да осигуриш перфектен резултат.</p>
          </div></div>
        </details>

        <details class="faq-details" name="lp-faq">
          <summary class="faq-details__summary">
            <span class="faq-details__question" data-i18n="pages.mikrobleiding.faq.items.4.question">Подходящо ли е за всички типове кожа?</span>
            <span class="faq-details__chevron" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="faq-details__chevron-svg"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </summary>
          <div class="faq-details__content"><div class="faq-details__inner">
            <p class="faq-details__answer" data-i18n="pages.mikrobleiding.faq.items.4.answer">Процедурата е подходяща за повечете типове кожа. При по-мазна кожа резултатите може да издържат малко по-кратко, но с правилна поддръжка и ретуш резултатът остава красив. На консултацията обсъждаме твоя конкретен случай и очаквания.</p>
          </div></div>
        </details>

        <details class="faq-details" name="lp-faq">
          <summary class="faq-details__summary">
            <span class="faq-details__question" data-i18n="pages.mikrobleiding.faq.items.5.question">Колко струва микроблейдингът?</span>
            <span class="faq-details__chevron" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="faq-details__chevron-svg"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </summary>
          <div class="faq-details__content"><div class="faq-details__inner">
            <p class="faq-details__answer" data-i18n="pages.mikrobleiding.faq.items.5.answer">Цената варира в зависимост от процедурата и опита на специалиста. За точна информация относно цените ми, свържи се с мен директно — ще ти отговоря бързо и с удоволствие.</p>
          </div></div>
        </details>

      </div>
    </div>
  </section>


