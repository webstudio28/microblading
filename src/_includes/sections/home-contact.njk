{% set c = home.contact if home and home.contact else {} %}
<section
  id="contact"
  class="mb-section scroll-mt-20 section-padding bg-white/70"
  aria-labelledby="contact-heading"
>
  <div class="container-custom">
    <header class="mb-header text-center mx-auto mb-8">
      <span class="mb-eyebrow justify-center">Свържи се с мен</span>
      <h2 id="contact-heading" class="mb-title text-center mt-2">Контакти</h2>
    </header>

    <div class="contact-min-grid">
      <div class="contact-min-card">
        {% if c.addresses and c.addresses.length %}
        <h3 class="contact-min-title">Адреси</h3>
        <ul class="mb-4 list-none space-y-1.5 text-[#5a483e]">
          {% for line in c.addresses %}
          <li>{{ line }}</li>
          {% endfor %}
        </ul>
        {% endif %}

        <h3 class="contact-min-title{% if not (c.addresses and c.addresses.length) %} mt-0{% endif %}">Директен контакт</h3>
        <div class="contact-min-links">
          <a class="contact-min-link" href="tel:{{ c.phoneHref | default('+359887621922') }}">
            Телефон: {{ c.phoneLabel | default('0887 621 922') }}
          </a>
          <a class="contact-min-link" href="mailto:{{ c.email | default('phibrowsvm@gmail.com') }}">
            Имейл: {{ c.email | default('phibrowsvm@gmail.com') }}
          </a>
          <a class="contact-min-link" href="{{ c.viber | default('viber://chat?number=%2B359887621922') }}" target="_blank" rel="noopener noreferrer">
            Viber
          </a>
          <a class="contact-min-link" href="{{ c.whatsapp | default('https://wa.me/359887621922') }}" target="_blank" rel="noopener noreferrer">
            WhatsApp
          </a>
        </div>

        <h3 class="contact-min-title mt-6">Социални мрежи</h3>
        <div class="contact-min-socials">
          {% if c.instagram %}
          <a class="contact-min-pill" href="{{ c.instagram }}" target="_blank" rel="noopener noreferrer">Instagram @phibrows_valyamatovska</a>
          {% endif %}
          {% if c.facebook %}
          <a class="contact-min-pill" href="{{ c.facebook }}" target="_blank" rel="noopener noreferrer">Facebook</a>
          {% endif %}
          {% if c.tiktok %}
          <a class="contact-min-pill" href="{{ c.tiktok }}" target="_blank" rel="noopener noreferrer">TikTok</a>
          {% endif %}
        </div>
      </div>

      <div class="contact-min-map">
        <iframe
          src="{{ c.mapEmbedUrl | default('https://maps.google.com/maps?q=%D1%83%D0%BB.%20%D0%91%D0%BE%D1%80%D0%B8%D1%81%20%D0%A1%D0%B0%D1%80%D0%B0%D1%84%D0%BE%D0%B2%2011%2C%20%D0%9F%D0%BB%D0%BE%D0%B2%D0%B4%D0%B8%D0%B2%2C%20%D0%91%D1%8A%D0%BB%D0%B3%D0%B0%D1%80%D0%B8%D1%8F&output=embed') }}"
          width="600"
          height="450"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Локация в Google Maps — Пловдив"
        ></iframe>
      </div>
    </div>
  </div>
</section>
