{% set c = home.contact if home and home.contact else {} %}
{% set addr = c.addresses if c.addresses else [] %}
<section
  id="contact"
  class="mb-section section-padding bg-white/70"
  aria-labelledby="contact-heading"
>
  <div class="container-custom">
    <header class="mb-header mx-auto mb-10 text-center md:mb-14">
      <span class="mb-eyebrow justify-center" data-i18n="ui.getInTouch">Свържи се с мен</span>
      <h2 id="contact-heading" class="mb-title mt-2 text-center" data-i18n="ui.contacts">
        Контакти
      </h2>
      {% if c.lead %}
      <p class="site-lead mx-auto mt-4 max-w-2xl text-center text-muted" data-i18n="home.contact.lead">
        {{ c.lead }}
      </p>
      {% endif %}
    </header>

    {% include "contact-cards-grid.njk" %}

  </div>
</section>
