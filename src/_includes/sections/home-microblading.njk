{% set m = home.microblading if home and home.microblading else {} %}
<section
  id="microblading"
  class="scroll-mt-20 section-padding"
  aria-labelledby="microblading-heading"
>
  <div class="container-custom">

    {% if m.eyebrow %}
    <p class="font-sans text-[11px] font-medium tracking-wide text-[#713f12]">
      {{ m.eyebrow }}
    </p>
    {% endif %}

    <h2
      id="microblading-heading"
      class="font-mak mt-2 text-[2.25rem] font-bold leading-10 tracking-wider text-yellow-900 md:text-[2.5rem] md:leading-[2.75rem]"
    >{{ m.title | default("Микроблейдинг") }}</h2>

    {% if m.lead %}
    <p class="site-lead mt-4 w-full text-[#4a3728]">
      {{ m.lead }}
    </p>
    {% endif %}

    {% if m.sub %}
    <div class="section-sub-block">
      <h3 class="section-sub-heading">{{ m.sub.title }}</h3>
      {% if m.sub.body %}
      <p class="site-lead mt-5 w-full text-[#4a3728]">
        {{ m.sub.body }}
      </p>
      {% endif %}
    </div>
    {% endif %}

  </div>
</section>
