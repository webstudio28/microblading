{% set m = home.microblading if home and home.microblading else {} %}
{% set mb = microblading if microblading else {} %}
<section
  id="microblading"
  class="mb-section scroll-mt-20 section-padding"
  aria-labelledby="microblading-heading"
>
  <div class="container-custom relative">

    <header class="mb-header">
      {% if m.eyebrow %}
      <span class="mb-eyebrow">{{ m.eyebrow }}</span>
      {% endif %}

      <h2 id="microblading-heading" class="mb-title">
        {{ m.title | default("Микроблейдинг") }}
      </h2>

      {% if m.lead %}
      <p class="mb-lead">{{ m.lead }}</p>
      {% endif %}

      {% if m.sub %}
      <p class="mb-learn-inline">
        <button
          type="button"
          class="mb-learn-more-btn"
          data-mb-info-open
          aria-haspopup="dialog"
          aria-controls="mb-info-modal"
        >
          Научи повече
        </button>
      </p>
      {% endif %}
    </header>

  </div>

  {% if mb.gallery and mb.gallery.length %}
  <div class="mb-bubbles-wrap pt-10" data-mb-bubbles-wrap>
    <div class="container-custom">
      <div class="mb-bubbles-head">
        <p class="mb-bubbles-label" id="mb-gallery-heading">
          {{ m.galleryLabel | default("Галерия") }}
        </p>
        <div class="mb-bubbles-nav" aria-hidden="true">
          <button
            type="button"
            class="mb-bubbles-arrow mb-bubbles-arrow--prev"
            data-mb-bubbles-prev
            aria-label="Предишна снимка"
          >
            <svg class="mb-arrow-icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="21 8 12 16 21 24" vector-effect="non-scaling-stroke" />
            </svg>
          </button>
          <button
            type="button"
            class="mb-bubbles-arrow mb-bubbles-arrow--next"
            data-mb-bubbles-next
            aria-label="Следваща снимка"
          >
            <svg class="mb-arrow-icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="11 8 20 16 11 24" vector-effect="non-scaling-stroke" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="mb-bubbles" role="list" data-mb-bubbles aria-labelledby="mb-gallery-heading">
      {% for item in mb.gallery %}
      <figure
        class="mb-bubble"
        role="listitem"
        data-mb-gallery-trigger
        data-mb-gallery-index="{{ loop.index0 }}"
      >
        {% if item.src | isVideoPath %}
        <video
          src="{{ item.src | url }}"
          data-mb-gallery-item
          data-mb-gallery-index="{{ loop.index0 }}"
          muted
          playsinline
          loop
          preload="metadata"
          aria-label="{{ item.alt | default('Микроблейдинг — видео') }}"
        ></video>
        <span class="mb-bubble__video-badge" aria-hidden="true">
          <svg viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="28" cy="28" r="26" fill="rgba(255, 255, 255, 0.92)" stroke="rgba(44, 26, 14, 0.1)" stroke-width="1" />
            <path fill="#3a2415" d="M23 17v22l18-11-18-11Z" />
          </svg>
        </span>
        {% else %}
        <img
          src="{{ item.src | url }}"
          alt="{{ item.alt | default('Микроблейдинг снимка') }}"
          data-mb-gallery-item
          data-mb-gallery-index="{{ loop.index0 }}"
          loading="lazy"
          decoding="async"
        />
        {% endif %}
      </figure>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {% if m.sub %}
  <div
    id="mb-info-modal"
    class="mb-info-modal"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby="mb-info-modal-title"
    hidden
  >
    <div class="mb-info-modal__backdrop" data-mb-info-close></div>
    <div class="mb-info-modal__panel" role="document" tabindex="-1">
      <button
        type="button"
        class="mb-info-modal__close"
        data-mb-info-close
        aria-label="Затвори"
      >
        &times;
      </button>
      <h3 id="mb-info-modal-title" class="mb-info-modal__title">
        {{ m.sub.title }}
      </h3>
      {% if m.sub.body %}
      <p class="mb-info-modal__text">
        {{ m.sub.body }}
      </p>
      {% endif %}
    </div>
  </div>
  {% endif %}

  {% if mb.gallery and mb.gallery.length %}
  <div
    id="mb-gallery-modal"
    class="mb-gallery-modal"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-label="Галерия микроблейдинг"
    hidden
  >
    <div class="mb-gallery-modal__backdrop" data-mb-gallery-close></div>
    <div class="mb-gallery-modal__panel" role="document">
      <button
        type="button"
        class="mb-gallery-modal__close"
        data-mb-gallery-close
        aria-label="Затвори галерията"
      >
        &times;
      </button>

      <button
        type="button"
        class="mb-gallery-modal__arrow mb-gallery-modal__arrow--prev"
        data-mb-gallery-prev
        aria-label="Предишна снимка"
      >
        <svg class="mb-arrow-icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="21 8 12 16 21 24" vector-effect="non-scaling-stroke" />
        </svg>
      </button>

      <div class="mb-gallery-modal__stage" data-mb-gallery-stage>
        <div class="mb-gallery-modal__clip">
          <img class="mb-gallery-modal__image" data-mb-gallery-image src="" alt="" />
          <video
            class="mb-gallery-modal__image"
            data-mb-gallery-video
            playsinline
            controls
            hidden
          ></video>
        </div>
      </div>

      <button
        type="button"
        class="mb-gallery-modal__arrow mb-gallery-modal__arrow--next"
        data-mb-gallery-next
        aria-label="Следваща снимка"
      >
        <svg class="mb-arrow-icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="11 8 20 16 11 24" vector-effect="non-scaling-stroke" />
        </svg>
      </button>
    </div>
  </div>
  {% endif %}

</section>

<script>
  (function initMbSteps() {
    function enableHorizontalDrag(viewport) {
      if (!viewport) return;
      var isDown = false;
      var startX = 0;
      var startScroll = 0;
      var moved = false;
      var DRAG_THRESHOLD = 4;

      viewport.addEventListener("pointerdown", function (e) {
        if (e.pointerType === "touch") return;
        isDown = true;
        moved = false;
        startX = e.clientX;
        startScroll = viewport.scrollLeft;
        viewport.classList.add("is-dragging");
        try { viewport.setPointerCapture(e.pointerId); } catch (err) {}
      });

      viewport.addEventListener("pointermove", function (e) {
        if (!isDown) return;
        var dx = e.clientX - startX;
        if (Math.abs(dx) > DRAG_THRESHOLD) moved = true;
        viewport.scrollLeft = startScroll - dx;
      });

      function endDrag(e) {
        if (!isDown) return;
        isDown = false;
        viewport.classList.remove("is-dragging");
        if (e && e.pointerId != null) {
          try { viewport.releasePointerCapture(e.pointerId); } catch (err) {}
        }
      }
      viewport.addEventListener("pointerup", endDrag);
      viewport.addEventListener("pointercancel", endDrag);
      viewport.addEventListener("pointerleave", endDrag);

      viewport.addEventListener("click", function (e) {
        if (moved) {
          e.preventDefault();
          e.stopPropagation();
          moved = false;
        }
      }, true);

      viewport.addEventListener("dragstart", function (e) { e.preventDefault(); });
    }

    document.querySelectorAll("[data-mb-bubbles-wrap]").forEach(function (root) {
      var strip = root.querySelector("[data-mb-bubbles]");
      var prevBtn = root.querySelector("[data-mb-bubbles-prev]");
      var nextBtn = root.querySelector("[data-mb-bubbles-next]");
      if (!strip) return;

      function cardWidth() {
        var card = strip.querySelector(".mb-bubble");
        if (!card) return strip.clientWidth * 0.8;
        var cs = getComputedStyle(strip);
        var gap = parseFloat(cs.columnGap || cs.gap || "0") || 0;
        return card.getBoundingClientRect().width + gap;
      }

      function updateBubblesArrows() {
        var max = strip.scrollWidth - strip.clientWidth;
        var atStart = strip.scrollLeft <= 2;
        var atEnd = strip.scrollLeft >= max - 2;
        if (prevBtn) prevBtn.toggleAttribute("disabled", atStart);
        if (nextBtn) nextBtn.toggleAttribute("disabled", atEnd);
      }

      if (prevBtn) {
        prevBtn.addEventListener("click", function () {
          strip.scrollBy({ left: -cardWidth(), behavior: "smooth" });
        });
      }
      if (nextBtn) {
        nextBtn.addEventListener("click", function () {
          strip.scrollBy({ left: cardWidth(), behavior: "smooth" });
        });
      }

      strip.addEventListener("scroll", updateBubblesArrows, { passive: true });
      window.addEventListener("resize", updateBubblesArrows);
      updateBubblesArrows();

      if (window.matchMedia("(max-width: 767px)").matches) {
        enableHorizontalDrag(strip);
      }
    });

      var galleryModal = document.getElementById("mb-gallery-modal");
    if (galleryModal) {
      var galleryImage = galleryModal.querySelector("[data-mb-gallery-image]");
      var galleryVideo = galleryModal.querySelector("[data-mb-gallery-video]");
      var galleryStage = galleryModal.querySelector("[data-mb-gallery-stage]");
      var galleryItems = Array.prototype.slice.call(
        document.querySelectorAll("[data-mb-gallery-item]")
      );
      var galleryTriggers = Array.prototype.slice.call(
        document.querySelectorAll("[data-mb-gallery-trigger]")
      );
      var closeGalleryBtns = galleryModal.querySelectorAll("[data-mb-gallery-close]");
      var prevGalleryBtn = galleryModal.querySelector("[data-mb-gallery-prev]");
      var nextGalleryBtn = galleryModal.querySelector("[data-mb-gallery-next]");
      var galleryIndex = 0;

      function pauseModalVideo() {
        if (!galleryVideo) return;
        galleryVideo.pause();
        galleryVideo.src = "";
        try { galleryVideo.load(); } catch (err) {}
      }

      function renderGalleryImage() {
        if (!galleryItems.length) return;
        var source = galleryItems[galleryIndex];
        var isVideo = source.tagName === "VIDEO";

        if (isVideo) {
          if (galleryImage) {
            galleryImage.src = "";
            galleryImage.alt = "";
            galleryImage.style.display = "none";
          }
          if (galleryVideo) {
            var vsrc = source.currentSrc || source.getAttribute("src") || "";
            galleryVideo.src = vsrc;
            galleryVideo.setAttribute("aria-label", source.getAttribute("aria-label") || "Галерия микроблейдинг");
            galleryVideo.style.display = "block";
            galleryVideo.muted = false;
            try { galleryVideo.play(); } catch (err) {}
          }
        } else {
          pauseModalVideo();
          if (galleryVideo) galleryVideo.style.display = "none";
          if (galleryImage) {
            galleryImage.style.display = "block";
            galleryImage.src = source.currentSrc || source.src;
            galleryImage.alt = source.alt || "Галерия микроблейдинг";
          }
        }
      }

      function openGallery(index) {
        galleryIndex = Math.max(0, Math.min(index, galleryItems.length - 1));
        renderGalleryImage();
        galleryModal.hidden = false;
        galleryModal.setAttribute("aria-hidden", "false");
        document.body.classList.add("modal-open");
      }

      function closeGallery() {
        pauseModalVideo();
        if (galleryVideo) galleryVideo.style.display = "none";
        if (galleryImage) {
          galleryImage.style.display = "none";
          galleryImage.src = "";
          galleryImage.alt = "";
        }
        galleryModal.hidden = true;
        galleryModal.setAttribute("aria-hidden", "true");
        document.body.classList.remove("modal-open");
      }

      function nextImage() {
        if (!galleryItems.length) return;
        galleryIndex = (galleryIndex + 1) % galleryItems.length;
        renderGalleryImage();
      }

      function prevImage() {
        if (!galleryItems.length) return;
        galleryIndex = (galleryIndex - 1 + galleryItems.length) % galleryItems.length;
        renderGalleryImage();
      }

      galleryTriggers.forEach(function (item) {
        item.addEventListener("click", function (e) {
          var target = e.currentTarget;
          var rawIdx = target && target.getAttribute("data-mb-gallery-index");
          var idx = Number(rawIdx);
          if (!Number.isFinite(idx)) idx = 0;
          openGallery(idx);
        });
      });

      closeGalleryBtns.forEach(function (btn) {
        btn.addEventListener("click", closeGallery);
      });
      if (nextGalleryBtn) nextGalleryBtn.addEventListener("click", nextImage);
      if (prevGalleryBtn) prevGalleryBtn.addEventListener("click", prevImage);

      var swipeStartX = null;
      if (galleryStage) {
        galleryStage.addEventListener("touchstart", function (e) {
          if (!e.touches || !e.touches.length) return;
          swipeStartX = e.touches[0].clientX;
        }, { passive: true });
        galleryStage.addEventListener("touchend", function (e) {
          if (swipeStartX === null || !e.changedTouches || !e.changedTouches.length) return;
          var deltaX = e.changedTouches[0].clientX - swipeStartX;
          swipeStartX = null;
          if (Math.abs(deltaX) < 40) return;
          if (deltaX < 0) nextImage();
          else prevImage();
        });
      }

      document.addEventListener("keydown", function (e) {
        if (galleryModal.hidden) return;
        if (e.key === "Escape") closeGallery();
        if (e.key === "ArrowRight") nextImage();
        if (e.key === "ArrowLeft") prevImage();
      });
    }

    var infoModal = document.getElementById("mb-info-modal");
    if (infoModal) {
      var panel = infoModal.querySelector(".mb-info-modal__panel");
      var openBtns = document.querySelectorAll("[data-mb-info-open]");
      var closeBtns = infoModal.querySelectorAll("[data-mb-info-close]");

      function openInfoModal() {
        infoModal.hidden = false;
        infoModal.setAttribute("aria-hidden", "false");
        document.body.classList.add("modal-open");
        if (panel) panel.focus();
      }

      function closeInfoModal() {
        infoModal.hidden = true;
        infoModal.setAttribute("aria-hidden", "true");
        document.body.classList.remove("modal-open");
      }

      openBtns.forEach(function (btn) {
        btn.addEventListener("click", openInfoModal);
      });
      closeBtns.forEach(function (btn) {
        btn.addEventListener("click", closeInfoModal);
      });

      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape" && !infoModal.hidden) {
          closeInfoModal();
        }
      });
    }
  })();
</script>
