{% set f = home.faq if home and home.faq else {} %}
{% set items = f.items if f.items else [] %}
{% set faqVisibleCount = f.homePreviewCount | default(5) %}
<section
  id="faq"
  class="mb-section section-padding bg-white/70 scroll-mt-20"
  aria-labelledby="faq-heading"
  data-faq
>
  <div class="container-custom">
    <header class="mb-header mx-auto mb-8 text-center md:mb-10">
      <span class="mb-eyebrow justify-center" data-i18n="home.faq.eyebrow" data-anim="eyebrow">{{ f.eyebrow | default("Въпроси и отговори") }}</span>
      <h2 id="faq-heading" class="mb-title mt-2 text-center" data-i18n="home.faq.title" data-anim="title">
        {{ f.title | default("Често задавани въпроси") }}
      </h2>
      {% if f.pageLead %}
      <p class="site-lead mx-auto mt-4 max-w-2xl text-center text-muted" data-i18n="home.faq.pageLead">
        {{ f.pageLead }}
      </p>
      {% endif %}
    </header>

    {% if items and items.length %}
    <div class="w-full" data-faq-list>
      <div class="w-full" data-faq-accordion>
        <div class="faq-stack w-full">
          {% for item in items %}
          {% if loop.index0 < faqVisibleCount %}
          <details class="faq-details" data-anim="faq-item">
            <summary class="faq-details__summary">
              <span class="faq-details__question" data-i18n="home.faq.items.{{ loop.index0 }}.question">{{ item.question }}</span>
              <span class="faq-details__chevron" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="faq-details__chevron-svg">
                  <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </summary>
            <div class="faq-details__content">
              <div class="faq-details__inner">
                <p class="faq-details__answer" data-i18n="home.faq.items.{{ loop.index0 }}.answer">{{ item.answer }}</p>
              </div>
            </div>
          </details>
          {% endif %}
          {% endfor %}
        </div>

        {% if items.length > faqVisibleCount %}
        <div class="faq-extra relative mt-2" data-faq-extra>
          <div class="faq-extra-peek relative">
          <div class="faq-stack faq-extra-inner w-full" data-faq-extra-inner>
            {% for item in items %}
            {% if loop.index0 >= faqVisibleCount %}
            <details class="faq-details" data-anim="faq-item">
              <summary class="faq-details__summary">
                <span class="faq-details__question" data-i18n="home.faq.items.{{ loop.index0 }}.question">{{ item.question }}</span>
                <span class="faq-details__chevron" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="faq-details__chevron-svg">
                    <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </summary>
              <div class="faq-details__content">
                <div class="faq-details__inner">
                  <p class="faq-details__answer" data-i18n="home.faq.items.{{ loop.index0 }}.answer">{{ item.answer }}</p>
                </div>
              </div>
            </details>
            {% endif %}
            {% endfor %}
          </div>
          <div class="faq-extra-fade pointer-events-none absolute inset-x-0 bottom-0 z-[1] h-20" data-faq-fade aria-hidden="true"></div>
          </div>
          <div class="faq-extra-actions relative z-[2] flex justify-center">
            <button
              type="button"
              class="faq-see-more inline-flex items-center gap-2 rounded-2xl border border-[rgba(193,163,138,0.55)] bg-[#faf9f6] px-6 py-3 text-base font-semibold text-ink shadow-[0_8px_22px_rgba(44,26,14,0.06)] transition-colors hover:border-[rgba(173,143,121,0.75)] hover:bg-white focus:outline-none focus-visible:ring-2 focus-visible:ring-[#c9a98a] focus-visible:ring-offset-2"
              data-faq-expand
              aria-expanded="false"
            >
              <span data-faq-expand-label>Виж още</span>
              <svg class="faq-see-more-icon h-4 w-4 shrink-0 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </button>
          </div>
        </div>
        {% endif %}
      </div>
    </div>
    {% endif %}
  </div>
</section>

<script src="{{ '/assets/js/faq-show-more.js' | url }}" defer></script>
{% include "faq-accordion-script.njk" %}
