{% set f = home.faq if home and home.faq else {} %}
{% set items = f.items if f.items else [] %}
{% set previewCount = f.homePreviewCount | default(5) %}
<section
  id="faq"
  class="mb-section section-padding bg-white/70 scroll-mt-20"
  aria-labelledby="faq-heading"
>
  <div class="container-custom">
    <header class="mb-header mx-auto mb-8 text-center md:mb-10">
      <span class="mb-eyebrow justify-center" data-i18n="home.faq.eyebrow">{{ f.eyebrow | default("Въпроси и отговори") }}</span>
      <h2 id="faq-heading" class="mb-title mt-2 text-center" data-i18n="home.faq.title">
        {{ f.title | default("Често задавани въпроси") }}
      </h2>
    </header>

    {% if items and items.length %}
    {% set faqItems = items %}
    {% set faqLimit = previewCount %}
    {% set faqAccordionName = "home-faq" %}
    {% include "faq-accordion.njk" %}

    {% if items.length > previewCount %}
    <p class="faq-section__cta">
      <a href="{{ (f.viewAllUrl | default('/faq/')) | url }}" class="faq-section__cta-btn">
        <span data-i18n="home.faq.viewAllLabel">{{ f.viewAllLabel | default("Виж всички") }}</span>
        <span class="faq-section__cta-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="18" height="18">
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>
    </p>
    {% endif %}
    {% endif %}
  </div>
</section>

{% include "faq-accordion-script.njk" %}
