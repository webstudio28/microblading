{#-
  Required: baClients (array)
  Optional:
    baSectionId, baHeadingId, baSectionClass
    baEyebrow, baTitle, baLead
    baEyebrowI18n, baTitleI18n, baLeadI18n
    baEmptyNote
    baSingleImage (true = one combined image, no before/after labels or procedure text)
    baAltI18nPrefix (i18n key prefix for image alt, default homeBeforeAfter)
-#}
{% set baList = baClients if baClients else [] %}
{% set baAltKey = baAltI18nPrefix | default("homeBeforeAfter") %}
{% set baId = baSectionId | default("clients") %}
{% set baHeading = baHeadingId | default(baId ~ "-heading") %}
{% set baClass = baSectionClass | default("clients-section section-padding") %}

{% if baList and baList.length %}
<section
  id="{{ baId }}"
  class="{{ baClass }}"
  aria-labelledby="{{ baHeading }}"
>
  <div class="container-custom relative">
    <header class="mb-header text-center mx-auto mb-10">
      {% if baEyebrow or baEyebrowI18n %}
      <span class="mb-eyebrow justify-center"{% if baEyebrowI18n %} data-i18n="{{ baEyebrowI18n }}"{% endif %} data-anim="eyebrow">{{ baEyebrow }}</span>
      {% endif %}
      <h2 id="{{ baHeading }}" class="mb-title text-center mt-2"{% if baTitleI18n %} data-i18n="{{ baTitleI18n }}"{% endif %} data-anim="title">
        {{ baTitle | default("Преди / След") }}
      </h2>
      {% if baLead or baLeadI18n %}
      <p class="site-lead mt-3 text-center opacity-80"{% if baLeadI18n %} data-i18n="{{ baLeadI18n }}"{% endif %}>
        {{ baLead }}
      </p>
      {% endif %}
    </header>
  </div>

  <div class="strip-desktop-only clients-wrap" data-clients-wrap>
    <div class="clients-strip-wrapper">
      <div class="clients-strip" role="list" data-clients-strip>
        <div class="clients-strip-set">
        {% for client in baList %}
        {% set i18nIdx = client.i18nIndex if client.i18nIndex is defined else loop.index0 %}
        <div class="client-card{% if baSingleImage %} client-card--single{% endif %}" data-client-id="{{ client.id }}">
          <div class="client-card__visual">
            {% if baSingleImage %}
            <img
              src="{{ client.image | optImg(800) | url }}"
              alt="{{ client.alt | default('Преди и след — резултат') }}"
              class="client-card__img"
              loading="lazy"
              decoding="async"
              draggable="false"
              data-i18n-attr="alt:{{ baAltKey }}.{{ i18nIdx }}.alt"
            >
            {% else %}
            <div class="client-card__half">
              <img src="{{ client.beforeImage | optImg(520) | url }}" alt="{{ client.name }} преди" class="client-card__img" loading="lazy" decoding="async" draggable="false">
              <span class="client-card__label" data-i18n="ui.before">Преди</span>
            </div>
            <div class="client-card__half">
              <img src="{{ client.afterImage | optImg(520) | url }}" alt="{{ client.name }} след" class="client-card__img" loading="lazy" decoding="async" draggable="false">
              <span class="client-card__label" data-i18n="ui.after">След</span>
            </div>
            {% endif %}
          </div>
          {% if not baSingleImage and client.services and client.services.length %}
          <p class="client-card__procedure" aria-label="Процедура">
            {% for svc in client.services %}
            <span class="client-card__procedure-item" data-i18n="clients.{{ i18nIdx }}.services.0">{{ svc }}</span>{% if not loop.last %}<span class="client-card__procedure-sep" aria-hidden="true">·</span>{% endif %}
            {% endfor %}
          </p>
          {% endif %}
        </div>
        {% endfor %}
        </div>
        <div class="clients-strip-set" aria-hidden="true">
        {% for client in baList %}
        {% set i18nIdx = client.i18nIndex if client.i18nIndex is defined else loop.index0 %}
        <div class="client-card{% if baSingleImage %} client-card--single{% endif %}" data-client-id="{{ client.id }}">
          <div class="client-card__visual">
            {% if baSingleImage %}
            <img
              src="{{ client.image | optImg(800) | url }}"
              alt=""
              class="client-card__img"
              loading="lazy"
              decoding="async"
              draggable="false"
              data-i18n-attr="alt:{{ baAltKey }}.{{ i18nIdx }}.alt"
            >
            {% else %}
            <div class="client-card__half">
              <img src="{{ client.beforeImage | optImg(520) | url }}" alt="" class="client-card__img" loading="lazy" decoding="async" draggable="false">
              <span class="client-card__label" data-i18n="ui.before">Преди</span>
            </div>
            <div class="client-card__half">
              <img src="{{ client.afterImage | optImg(520) | url }}" alt="" class="client-card__img" loading="lazy" decoding="async" draggable="false">
              <span class="client-card__label" data-i18n="ui.after">След</span>
            </div>
            {% endif %}
          </div>
          {% if not baSingleImage and client.services and client.services.length %}
          <p class="client-card__procedure" aria-label="Процедура">
            {% for svc in client.services %}
            <span class="client-card__procedure-item" data-i18n="clients.{{ i18nIdx }}.services.0">{{ svc }}</span>{% if not loop.last %}<span class="client-card__procedure-sep" aria-hidden="true">·</span>{% endif %}
            {% endfor %}
          </p>
          {% endif %}
        </div>
        {% endfor %}
        </div>
      </div>
    </div>
  </div>

  {% include "sections/strip-mobile-before-after.njk" %}
</section>
{% elif baEmptyNote %}
<section id="{{ baId }}" class="{{ baClass }}">
  <div class="container-custom">
    <p class="mx-auto max-w-2xl text-center text-[#5a483e]">{{ baEmptyNote }}</p>
  </div>
</section>
{% endif %}
