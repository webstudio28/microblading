{% set a = home.about if home and home.about else {} %}
{% from "macros/image.njk" import responsiveImg %}
<section
  id="about"
  class="relative section-padding bg-gradient-to-br from-[#A48C77] to-[#C1AE9A]"
  aria-labelledby="about-heading"
>
  <div class="container-custom relative z-10">

    {# Row 1: section heading + intro (full width of container) #}
    <header class="mb-header mx-auto mb-6 text-center md:mb-8">
      <h2
        id="about-heading"
        class="mb-title mt-2 text-center text-white"
        data-i18n="home.about.title"
        data-anim="title"
      >{{ a.title | default("За мен") }}</h2>

      {% if a.intro %}
      <p class="site-lead mt-3 hidden text-center text-white md:mx-auto md:block md:max-w-2xl" data-i18n="home.about.intro" data-anim="about-intro">
        {{ a.intro }}
      </p>
      {% endif %}
    </header>

    {# Same photos as modal: 1 col mobile, 2 cols md–lg, 3 cols lg+ #}
    <div class="about-section__photos mx-auto grid w-full max-w-5xl grid-cols-1 gap-3 sm:gap-4 md:grid-cols-2 lg:grid-cols-3">
      {{ responsiveImg('/assets/images/za-men2.jpg', {
        alt: 'За мен — снимка 1',
        class: 'aspect-[3/4] w-full rounded-xl object-cover shadow-[0_8px_24px_rgba(0,0,0,0.12)]',
        width: 480,
        height: 640,
        maxWidth: 800,
        sizes: '(min-width: 1024px) 320px, (min-width: 768px) 50vw, 100vw',
        attrs: 'data-anim="about-photo"'
      }) }}
      {{ responsiveImg('/assets/images/za-men1.jpg', {
        alt: 'За мен — снимка 2',
        class: 'hidden aspect-[3/4] w-full rounded-xl object-cover shadow-[0_8px_24px_rgba(0,0,0,0.12)] md:block',
        width: 480,
        height: 640,
        maxWidth: 800,
        sizes: '(min-width: 1024px) 320px, 50vw',
        attrs: 'data-anim="about-photo"'
      }) }}
      {{ responsiveImg('/assets/images/za-men3.jpg', {
        alt: 'За мен — снимка 3',
        class: 'hidden aspect-[3/4] w-full rounded-xl object-cover shadow-[0_8px_24px_rgba(0,0,0,0.12)] lg:block',
        width: 480,
        height: 640,
        maxWidth: 800,
        sizes: '(min-width: 1024px) 320px, 33vw',
        attrs: 'data-anim="about-photo"'
      }) }}
    </div>

    <div class="mx-auto mt-6 flex w-full max-w-3xl flex-col items-center text-center md:mt-8">
      <p class="mb-lead mt-0 max-w-none text-white/90" data-i18n="home.about.body" data-anim="about-body">
        {{ a.body | default("") }}
      </p>

      {% if a.cta %}
      <div class="mt-7 flex w-full justify-center" data-anim="about-cta">
        <button
          type="button"
          class="inline-flex min-w-[220px] items-center justify-center rounded-3xl bg-zinc-800 px-8 py-3.5 text-center font-['Montserrat_Alternates'] text-base font-medium tracking-wide text-white shadow-[0px_4px_4px_0px_rgba(0,0,0,0.21)] transition-colors hover:bg-zinc-700"
          data-about-info-open
          aria-haspopup="dialog"
          aria-controls="about-info-modal"
        data-i18n="home.about.cta.label"
        >{{ a.cta.label }}</button>
      </div>
      {% endif %}
    </div>

  </div>

  <div
    id="about-info-modal"
    class="mb-info-modal"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby="about-info-modal-title"
    hidden
  >
    <div class="mb-info-modal__backdrop" data-about-info-close></div>
    <div class="mb-info-modal__panel" role="document" tabindex="-1">
      <button
        type="button"
        class="mb-info-modal__close"
        data-about-info-close
        aria-label="Затвори"
      >
        &times;
      </button>
      <h3 id="about-info-modal-title" class="mb-info-modal__title" data-i18n="home.about.title">
        {{ a.title | default("За мен") }}
      </h3>
      {% if a.body2 %}
      <p class="mb-info-modal__text text-[1.02rem] leading-[1.72]" data-i18n="home.about.body2">
        {{ a.body2 }}
      </p>
      {% endif %}

      <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
        {{ responsiveImg('/assets/images/za-men1.jpg', { alt: 'За мен - снимка 1', class: 'about-modal-media aspect-[3/4] w-full cursor-pointer rounded-xl object-cover', width: 480, height: 640, maxWidth: 520, sizes: '(min-width: 640px) 33vw, 50vw', attrs: 'data-about-media-trigger data-about-media-type="image" data-about-media-src="' ~ ('/assets/images/za-men1.jpg' | optGalleryUrl | url) ~ '"' }) }}
        {{ responsiveImg('/assets/images/za-men2.jpg', { alt: 'За мен - снимка 2', class: 'about-modal-media aspect-[3/4] w-full cursor-pointer rounded-xl object-cover', width: 480, height: 640, maxWidth: 520, sizes: '(min-width: 640px) 33vw, 50vw', attrs: 'data-about-media-trigger data-about-media-type="image" data-about-media-src="' ~ ('/assets/images/za-men2.jpg' | optGalleryUrl | url) ~ '"' }) }}
        {{ responsiveImg('/assets/images/za-men3.jpg', { alt: 'За мен - снимка 3', class: 'about-modal-media aspect-[3/4] w-full cursor-pointer rounded-xl object-cover', width: 480, height: 640, maxWidth: 520, sizes: '(min-width: 640px) 33vw, 50vw', attrs: 'data-about-media-trigger data-about-media-type="image" data-about-media-src="' ~ ('/assets/images/za-men3.jpg' | optGalleryUrl | url) ~ '"' }) }}
        <div class="about-modal-media relative aspect-[3/4] w-full cursor-pointer overflow-hidden rounded-xl" data-about-media-trigger data-about-media-type="video" data-about-media-src="{{ '/assets/images/about-me1.mp4' | url }}">
          <video src="{{ '/assets/images/about-me1.mp4' | url }}" class="h-full w-full object-cover" muted playsinline loop preload="metadata" aria-label="За мен — видео 1"></video>
          <span class="pointer-events-none absolute inset-0 flex items-center justify-center"><svg viewBox="0 0 56 56" fill="none" class="h-14 w-14"><circle cx="28" cy="28" r="26" fill="rgba(255,255,255,0.88)"/><path fill="#3a2415" d="M23 17v22l18-11-18-11Z"/></svg></span>
        </div>
        <div class="about-modal-media relative aspect-[3/4] w-full cursor-pointer overflow-hidden rounded-xl" data-about-media-trigger data-about-media-type="video" data-about-media-src="{{ '/assets/images/about-me2.mp4' | url }}">
          <video src="{{ '/assets/images/about-me2.mp4' | url }}" class="h-full w-full object-cover" muted playsinline loop preload="metadata" aria-label="За мен — видео 2"></video>
          <span class="pointer-events-none absolute inset-0 flex items-center justify-center"><svg viewBox="0 0 56 56" fill="none" class="h-14 w-14"><circle cx="28" cy="28" r="26" fill="rgba(255,255,255,0.88)"/><path fill="#3a2415" d="M23 17v22l18-11-18-11Z"/></svg></span>
        </div>
        <div class="about-modal-media relative aspect-[3/4] w-full cursor-pointer overflow-hidden rounded-xl" data-about-media-trigger data-about-media-type="video" data-about-media-src="{{ '/assets/images/about-me3.mp4' | url }}">
          <video src="{{ '/assets/images/about-me3.mp4' | url }}" class="h-full w-full object-cover" muted playsinline loop preload="metadata" aria-label="За мен — видео 3"></video>
          <span class="pointer-events-none absolute inset-0 flex items-center justify-center"><svg viewBox="0 0 56 56" fill="none" class="h-14 w-14"><circle cx="28" cy="28" r="26" fill="rgba(255,255,255,0.88)"/><path fill="#3a2415" d="M23 17v22l18-11-18-11Z"/></svg></span>
        </div>
      </div>

    </div>
  </div>
</section>

{# Media lightbox — separate modal, above everything else #}
<div
  id="about-media-viewer"
  role="dialog"
  aria-modal="true"
  aria-label="Преглед на медия"
  aria-hidden="true"
  hidden
  style="position:fixed;inset:0;z-index:6000;background:rgba(0,0,0,0.92);display:none;align-items:center;justify-content:center;"
>
  <button
    type="button"
    data-about-media-close
    aria-label="Затвори"
    style="position:absolute;top:1rem;right:1.25rem;background:none;border:none;color:#fff;font-size:2rem;line-height:1;cursor:pointer;"
  >&times;</button>
  <img id="about-media-viewer-image" src="" alt="" style="max-height:90vh;max-width:90vw;border-radius:0.75rem;object-fit:contain;display:none;" />
  <video id="about-media-viewer-video" playsinline muted loop style="max-height:90vh;max-width:90vw;border-radius:0.75rem;display:none;"></video>
</div>

<script>
  (function initAboutModal() {
    var modal = document.getElementById("about-info-modal");
    if (!modal) return;

    var panel = modal.querySelector(".mb-info-modal__panel");
    var openBtns = document.querySelectorAll("[data-about-info-open]");
    var closeBtns = modal.querySelectorAll("[data-about-info-close]");

    function openModal() {
      modal.hidden = false;
      modal.setAttribute("aria-hidden", "false");
      document.body.classList.add("modal-open");
      if (panel) panel.focus();
    }

    function closeModal() {
      modal.hidden = true;
      modal.setAttribute("aria-hidden", "true");
      document.body.classList.remove("modal-open");
    }

    openBtns.forEach(function (btn) {
      btn.addEventListener("click", openModal);
    });
    closeBtns.forEach(function (btn) {
      btn.addEventListener("click", closeModal);
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && !modal.hidden) {
        closeModal();
      }
    });

    // Media viewer (images + videos inside the modal)
    var viewer = document.getElementById("about-media-viewer");
    var viewerImage = document.getElementById("about-media-viewer-image");
    var viewerVideo = document.getElementById("about-media-viewer-video");

    function openViewer(type, src) {
      if (!viewer) return;
      viewer.hidden = false;
      viewer.setAttribute("aria-hidden", "false");
      viewer.style.display = "flex";
      if (type === "video") {
        if (viewerImage) viewerImage.style.display = "none";
        if (viewerVideo) {
          viewerVideo.src = src;
          viewerVideo.style.display = "block";
          viewerVideo.muted = true;
          try { viewerVideo.play(); } catch (err) {}
        }
      } else {
        if (viewerVideo) { viewerVideo.pause(); viewerVideo.style.display = "none"; }
        if (viewerImage) { viewerImage.src = src; viewerImage.style.display = "block"; }
      }
    }

    function closeViewer() {
      if (!viewer) return;
      viewer.hidden = true;
      viewer.setAttribute("aria-hidden", "true");
      viewer.style.display = "none";
      if (viewerVideo) { viewerVideo.pause(); viewerVideo.src = ""; viewerVideo.style.display = "none"; }
      if (viewerImage) { viewerImage.src = ""; viewerImage.style.display = "none"; }
    }

    // Attach triggers from the about-info modal panel
    document.querySelectorAll("[data-about-media-trigger]").forEach(function (el) {
      el.addEventListener("click", function () {
        openViewer(el.getAttribute("data-about-media-type"), el.getAttribute("data-about-media-src"));
      });
    });

    if (viewer) {
      viewer.querySelectorAll("[data-about-media-close]").forEach(function (btn) {
        btn.addEventListener("click", closeViewer);
      });
      viewer.addEventListener("click", function (e) {
        if (e.target === viewer) closeViewer();
      });
    }

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") {
        if (viewer && !viewer.hidden) { closeViewer(); return; }
      }
    });
  })();
</script>
