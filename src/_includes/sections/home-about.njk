{% set a = home.about if home and home.about else {} %}
<section
  id="about"
  class="relative scroll-mt-20 section-padding bg-gradient-to-br from-[#A48C77] to-[#C1AE9A]"
  aria-labelledby="about-heading"
>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 hidden h-[30%] bg-[#C1AE9A] md:block" aria-hidden="true"></div>

  <div class="container-custom relative z-10">

    {# Row 1: section heading + intro (full width of container) #}
    <header class="mb-header text-center mx-auto mb-10">
      <h2
        id="about-heading"
        class="mb-title text-center mt-2 text-white"
      >{{ a.title | default("За мен") }}</h2>

      {% if a.intro %}
      <p class="site-lead mt-3 text-center mx-auto max-w-2xl text-white">
        {{ a.intro }}
      </p>
      {% endif %}
    </header>

    {# Row 2: image | right rail (text + CTA = 90% of space beside image, flush right) #}
    <div class="mt-8 flex flex-col gap-6 md:flex-row md:items-start">

      {# Left: photo #}
      <img
        src="{{ a.image | default('/assets/images/about-me.jpg') | url }}"
        alt="{{ a.imageAlt | default('') }}"
        class="h-[420px] w-full max-w-[320px] shrink-0 self-start rounded-[20px] object-cover object-top md:w-[320px]"
        width="320"
        height="420"
        loading="lazy"
        decoding="async"
      >

      {# Fills space to the right of the image; inner column is 90% wide and right-aligned #}
      <div class="flex min-w-0 flex-1 justify-end">
        <div class="flex w-full min-w-0 flex-col min-h-0 md:min-h-[420px] md:w-[90%]">

          <p class="mb-lead mt-0 max-w-none text-white/80">
            {{ a.body | default("") }}
          </p>

          {% if a.body2 %}
          <p class="mb-lead mt-5 hidden max-w-none text-white/80 md:block">
            {{ a.body2 }}
          </p>
          {% endif %}

          {% if a.cta %}
          <div class="mt-auto w-full pt-8">
            <button
              type="button"
              class="block w-full rounded-3xl bg-zinc-800 py-3.5 text-center font-['Montserrat_Alternates'] text-base font-medium tracking-wide text-white shadow-[0px_4px_4px_0px_rgba(0,0,0,0.21)] transition-colors hover:bg-zinc-700"
              data-about-info-open
              aria-haspopup="dialog"
              aria-controls="about-info-modal"
            >{{ a.cta.label }}</button>
          </div>
          {% endif %}

        </div>
      </div>
    </div>

  </div>

  <div
    id="about-info-modal"
    class="mb-info-modal"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby="about-info-modal-title"
    hidden
  >
    <div class="mb-info-modal__backdrop" data-about-info-close></div>
    <div class="mb-info-modal__panel" role="document" tabindex="-1">
      <button
        type="button"
        class="mb-info-modal__close"
        data-about-info-close
        aria-label="Затвори"
      >
        &times;
      </button>
      <h3 id="about-info-modal-title" class="mb-info-modal__title">
        {{ a.title | default("За мен") }}
      </h3>
      <p class="mb-info-modal__text text-[1.02rem] leading-[1.72]">
        {{ a.body | default("") }}
      </p>
      {% if a.body2 %}
      <p class="mb-info-modal__text text-[1.02rem] leading-[1.72]">
        {{ a.body2 }}
      </p>
      {% endif %}

      <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
        <img src="{{ '/assets/images/za-men1.jpg' | url }}" alt="За мен - снимка 1" class="h-40 w-full rounded-xl object-cover" loading="lazy" decoding="async" />
        <img src="{{ '/assets/images/za-men2.jpg' | url }}" alt="За мен - снимка 2" class="h-40 w-full rounded-xl object-cover" loading="lazy" decoding="async" />
        <img src="{{ '/assets/images/za-men3.jpg' | url }}" alt="За мен - снимка 3" class="h-40 w-full rounded-xl object-cover" loading="lazy" decoding="async" />
      </div>
    </div>
  </div>
</section>

<script>
  (function initAboutModal() {
    var modal = document.getElementById("about-info-modal");
    if (!modal) return;

    var panel = modal.querySelector(".mb-info-modal__panel");
    var openBtns = document.querySelectorAll("[data-about-info-open]");
    var closeBtns = modal.querySelectorAll("[data-about-info-close]");

    function openModal() {
      modal.hidden = false;
      modal.setAttribute("aria-hidden", "false");
      document.body.classList.add("modal-open");
      if (panel) panel.focus();
    }

    function closeModal() {
      modal.hidden = true;
      modal.setAttribute("aria-hidden", "true");
      document.body.classList.remove("modal-open");
    }

    openBtns.forEach(function (btn) {
      btn.addEventListener("click", openModal);
    });
    closeBtns.forEach(function (btn) {
      btn.addEventListener("click", closeModal);
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && !modal.hidden) {
        closeModal();
      }
    });
  })();
</script>
