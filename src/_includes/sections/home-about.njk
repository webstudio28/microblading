{% set a = home.about if home and home.about else {} %}
<section
  id="about"
  class="relative scroll-mt-20 section-padding bg-gradient-to-br from-[#A48C77] to-[#C1AE9A]"
  aria-labelledby="about-heading"
>
  <div class="container-custom relative z-10">

    {# Row 1: section heading + intro (full width of container) #}
    <header class="mb-header mx-auto mb-6 text-center md:mb-8">
      <h2
        id="about-heading"
        class="mb-title mt-2 text-center text-white"
      >{{ a.title | default("За мен") }}</h2>

      {% if a.intro %}
      <p class="site-lead mt-3 hidden text-center text-white md:mx-auto md:block md:max-w-2xl">
        {{ a.intro }}
      </p>
      {% endif %}
    </header>

    {# Same photos as modal: 1 col mobile, 2 cols md–lg, 3 cols lg+ #}
    <div class="about-section__photos mx-auto grid w-full max-w-5xl grid-cols-1 gap-3 sm:gap-4 md:grid-cols-2 lg:grid-cols-3">
      <img
        src="{{ '/assets/images/za-men1.jpg' | url }}"
        alt="За мен — снимка 1"
        class="aspect-[4/3] w-full rounded-xl object-cover shadow-[0_8px_24px_rgba(0,0,0,0.12)]"
        width="640"
        height="480"
        loading="lazy"
        decoding="async"
      >
      <img
        src="{{ '/assets/images/za-men2.jpg' | url }}"
        alt="За мен — снимка 2"
        class="hidden aspect-[4/3] w-full rounded-xl object-cover shadow-[0_8px_24px_rgba(0,0,0,0.12)] md:block"
        width="640"
        height="480"
        loading="lazy"
        decoding="async"
      >
      <img
        src="{{ '/assets/images/za-men3.jpg' | url }}"
        alt="За мен — снимка 3"
        class="hidden aspect-[4/3] w-full rounded-xl object-cover shadow-[0_8px_24px_rgba(0,0,0,0.12)] lg:block"
        width="640"
        height="480"
        loading="lazy"
        decoding="async"
      >
    </div>

    <div class="mx-auto mt-6 flex w-full max-w-3xl flex-col items-center text-center md:mt-8">
      <p class="mb-lead mt-0 max-w-none text-white/90">
        {{ a.body | default("") }}
      </p>

      {% if a.body2 %}
      <p class="mb-lead mt-4 max-w-none text-white/90">
        {{ a.body2 }}
      </p>
      {% endif %}

      {% if a.cta %}
      <div class="mt-7 flex w-full justify-center">
        <button
          type="button"
          class="inline-flex min-w-[220px] items-center justify-center rounded-3xl bg-zinc-800 px-8 py-3.5 text-center font-['Montserrat_Alternates'] text-base font-medium tracking-wide text-white shadow-[0px_4px_4px_0px_rgba(0,0,0,0.21)] transition-colors hover:bg-zinc-700"
          data-about-info-open
          aria-haspopup="dialog"
          aria-controls="about-info-modal"
        >{{ a.cta.label }}</button>
      </div>
      {% endif %}
    </div>

  </div>

  <div
    id="about-info-modal"
    class="mb-info-modal"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby="about-info-modal-title"
    hidden
  >
    <div class="mb-info-modal__backdrop" data-about-info-close></div>
    <div class="mb-info-modal__panel" role="document" tabindex="-1">
      <button
        type="button"
        class="mb-info-modal__close"
        data-about-info-close
        aria-label="Затвори"
      >
        &times;
      </button>
      <h3 id="about-info-modal-title" class="mb-info-modal__title">
        {{ a.title | default("За мен") }}
      </h3>
      <p class="mb-info-modal__text text-[1.02rem] leading-[1.72]">
        {{ a.body | default("") }}
      </p>
      {% if a.body2 %}
      <p class="mb-info-modal__text text-[1.02rem] leading-[1.72]">
        {{ a.body2 }}
      </p>
      {% endif %}

      <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
        <img src="{{ '/assets/images/za-men1.jpg' | url }}" alt="За мен - снимка 1" class="h-40 w-full rounded-xl object-cover" loading="lazy" decoding="async" />
        <img src="{{ '/assets/images/za-men2.jpg' | url }}" alt="За мен - снимка 2" class="h-40 w-full rounded-xl object-cover" loading="lazy" decoding="async" />
        <img src="{{ '/assets/images/za-men3.jpg' | url }}" alt="За мен - снимка 3" class="h-40 w-full rounded-xl object-cover" loading="lazy" decoding="async" />
      </div>
    </div>
  </div>
</section>

<script>
  (function initAboutModal() {
    var modal = document.getElementById("about-info-modal");
    if (!modal) return;

    var panel = modal.querySelector(".mb-info-modal__panel");
    var openBtns = document.querySelectorAll("[data-about-info-open]");
    var closeBtns = modal.querySelectorAll("[data-about-info-close]");

    function openModal() {
      modal.hidden = false;
      modal.setAttribute("aria-hidden", "false");
      document.body.classList.add("modal-open");
      if (panel) panel.focus();
    }

    function closeModal() {
      modal.hidden = true;
      modal.setAttribute("aria-hidden", "true");
      document.body.classList.remove("modal-open");
    }

    openBtns.forEach(function (btn) {
      btn.addEventListener("click", openModal);
    });
    closeBtns.forEach(function (btn) {
      btn.addEventListener("click", closeModal);
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && !modal.hidden) {
        closeModal();
      }
    });
  })();
</script>
