{% set h = home.hero if home and home.hero else {} %}
<section class="section-padding" id="hero">
  <div class="container-custom">
    <div class="rounded-3xl border border-slate-200 bg-gradient-to-br from-white to-slate-50 px-6 py-14 md:px-12 md:py-20">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold tracking-wide text-brand-secondary">One-page skeleton</p>
        <h1 class="mt-4 text-4xl md:text-5xl font-black leading-tight text-slate-900">
          {{ h.headline | default('Valeto landing page') }}
        </h1>
        {% if h.subheadline %}
        <p class="mt-5 text-lg md:text-xl text-slate-700">
          {{ h.subheadline }}
        </p>
        {% endif %}

        <div class="mt-8 flex flex-wrap gap-4">
          {% if h.ctaPrimary %}
          <a href="{{ h.ctaPrimary.url }}" class="px-6 py-3 rounded-xl bg-slate-900 text-white font-semibold hover:bg-slate-800">
            {{ h.ctaPrimary.label }}
          </a>
          {% endif %}
          {% if h.ctaSecondary %}
          <a href="{{ h.ctaSecondary.url }}" class="px-6 py-3 rounded-xl border-2 border-slate-900/15 text-slate-900 font-semibold hover:bg-slate-900/5">
            {{ h.ctaSecondary.label }}
          </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

