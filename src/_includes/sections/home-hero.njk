{% set h = home.hero if home and home.hero else {} %}
<section class="hero-section section-padding" id="hero">
  <div class="container-custom">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

      {# ── Left: text ── #}
      <div class="flex w-full min-w-0 flex-col items-start gap-5">

        {# Badge pill #}
        {% if h.badge %}
        <span class="hero-badge">{{ h.badge }}</span>
        {% endif %}

        {# Headline — MAK font #}
        <h1 class="font-mak text-5xl leading-[1.12] text-ink md:text-6xl md:leading-[1.1] xl:text-[4.25rem] xl:leading-[1.08]">
          {{ h.headline | default("Микроблейдинг и ламиниране в Пловдив") }}
        </h1>

        {# Sub-text — Montserrat #}
        {% if h.subheadline %}
        <p class="site-lead max-w-xl">
          {{ h.subheadline }}
        </p>
        {% endif %}

        {# CTAs — full width of column; buttons share row equally on sm+ #}
        <div class="mt-1 flex w-full min-w-0 flex-col gap-3 sm:flex-row sm:flex-nowrap">
          {% if h.ctaPrimary %}
          <a href="{{ h.ctaPrimary.url }}" class="btn-primary w-full min-w-0 sm:flex-1">
            {{ h.ctaPrimary.label }}
          </a>
          {% endif %}
          {% if h.ctaSecondary %}
          <a href="{{ h.ctaSecondary.url }}" class="btn-secondary w-full min-w-0 sm:flex-1">
            {{ h.ctaSecondary.label }}
          </a>
          {% endif %}
        </div>

      </div>

      {# ── Right: photo card ── #}
      <div class="flex justify-center lg:justify-end">
        <div class="hero-photo-wrap">
          <img
            src="{{ h.image | default('/assets/images/hero-img.jpeg') | url }}"
            alt="{{ h.imageAlt | default('Hero image') }}"
            class="hero-photo"
            width="460" height="540"
            loading="eager"
          >
        </div>
      </div>

    </div>
  </div>
</section>
