{% set h = home.hero if home and home.hero else {} %}
{% set heroImage = h.image | default('/assets/images/hero-img.jpeg') %}
<section class="hero-section section-padding" id="hero">
  <div class="container-custom">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-16 items-center">

      {# ── Left: text ── #}
      <div class="order-1 flex w-full min-w-0 flex-col items-center gap-5 text-center md:order-1 md:items-start md:text-left">

        {% if h.badge %}
        <span class="hero-badge hero-badge--signature hidden md:inline-flex" data-i18n="home.hero.badge">{{ h.badge }}</span>
        {% endif %}

        <h1 class="font-mak text-[2.35rem] leading-[1.12] text-ink md:text-6xl md:leading-[1.1] xl:text-[4.25rem] xl:leading-[1.08]" data-i18n="home.hero.headline">
          {{ h.headline | default("Микроблейдинг и ламиниране в Пловдив") }}
        </h1>

        <div class="flex w-full justify-center md:hidden">
          <div class="hero-photo-wrap w-full max-w-none">
            <picture>
              <source
                media="(max-width: 767px)"
                srcset="{{ '/assets/images/hero-img2-mobile.jpeg' | imgSrcset(828) | url }}"
                sizes="100vw"
              >
              <img
                src="{{ heroImage | optImg(1200) | url }}"
                srcset="{{ heroImage | imgSrcset(1200) | url }}"
                sizes="100vw"
                alt="{{ h.imageAlt | default('Hero image') }}"
                class="hero-photo"
                width="460" height="540"
                loading="eager"
                decoding="async"
                fetchpriority="high"
                data-i18n-attr="alt:home.hero.imageAlt"
              >
            </picture>
          </div>
        </div>

        {% if h.subheadline %}
        <p class="site-lead max-w-xl" data-i18n="home.hero.subheadline">
          {{ h.subheadline }}
        </p>
        {% endif %}

        <div class="mt-1 hidden w-full min-w-0 flex-row flex-nowrap gap-3 md:flex">
          {% if h.ctaPrimary %}
          <a
            href="{{ h.ctaPrimary.url }}"
            class="btn-primary min-w-0 flex-1"
            {% if h.ctaPrimary.external %}target="_blank" rel="noopener noreferrer"{% endif %}
            data-i18n="home.hero.ctaPrimary.label"
          >
            {{ h.ctaPrimary.label }}
          </a>
          {% endif %}
          {% if h.ctaSecondary %}
          <a href="{{ h.ctaSecondary.url }}" class="btn-secondary min-w-0 flex-1" data-i18n="home.hero.ctaSecondary.label">
            {{ h.ctaSecondary.label }}
          </a>
          {% endif %}
        </div>

      </div>

      <div class="order-2 hidden justify-center md:flex md:order-2 lg:justify-end">
        <div class="hero-photo-wrap">
          <picture>
            <source
              media="(max-width: 767px)"
              srcset="{{ '/assets/images/hero-img-mobile.jpg' | imgSrcset(828) | url }}"
              sizes="100vw"
            >
            <img
              src="{{ heroImage | optImg(1200) | url }}"
              srcset="{{ heroImage | imgSrcset(1200) | url }}"
              sizes="(min-width: 1024px) 460px, 50vw"
              alt="{{ h.imageAlt | default('Hero image') }}"
              class="hero-photo"
              width="460" height="540"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              data-i18n-attr="alt:home.hero.imageAlt"
            >
          </picture>
        </div>
      </div>

      <div class="order-3 mt-0.5 flex w-full min-w-0 flex-row flex-nowrap gap-2 md:hidden">
        {% if h.ctaPrimary %}
        <a
          href="{{ h.ctaPrimary.url }}"
          class="btn-primary min-w-0 flex-1 px-4 py-2 text-sm"
          {% if h.ctaPrimary.external %}target="_blank" rel="noopener noreferrer"{% endif %}
          data-i18n="home.hero.ctaPrimary.label"
        >
          {{ h.ctaPrimary.label }}
        </a>
        {% endif %}
        {% if h.ctaSecondary %}
        <a href="{{ h.ctaSecondary.url }}" class="btn-secondary min-w-0 flex-1 px-4 py-2 text-sm" data-i18n="home.hero.ctaSecondary.label">
          {{ h.ctaSecondary.label }}
        </a>
        {% endif %}
      </div>

    </div>
  </div>
</section>
