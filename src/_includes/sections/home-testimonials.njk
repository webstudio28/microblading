{% set t = home.testimonials if home and home.testimonials else {} %}
{% set items = t.items if t.items else [] %}
{% if items and items.length %}
<section
  id="testimonials"
  class="clients-section section-padding"
  aria-labelledby="testimonials-heading"
>
  <div class="container-custom">
    <header class="mb-header mx-auto mb-8 text-center md:mb-10">
      <span class="mb-eyebrow justify-center" data-i18n="home.testimonials.eyebrow">{{ t.eyebrow | default("Отзиви") }}</span>
      <h2 id="testimonials-heading" class="mb-title mt-2 text-center" data-i18n="home.testimonials.title">
        {{ t.title | default("Моите клиенти") }}
      </h2>
      {% if t.lead %}
      <p class="site-lead mx-auto mt-4 max-w-2xl text-center text-muted">
        {{ t.lead }}
      </p>
      {% endif %}
    </header>
  </div>

  <div class="testimonials-strip-wrapper">
    <div class="testimonials-strip" aria-label="Отзиви от клиенти" data-i18n-attr="aria-label:ui.reviewsFromClients">
      <div class="testimonials-strip-set">
        {% for item in items %}
        <article class="testimonial-card" data-testimonial-index="{{ loop.index0 }}">
          <div class="testimonial-card__stars" aria-hidden="true">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
          <p class="testimonial-card__quote" data-i18n="home.testimonials.items.{{ loop.index0 }}.quote">{{ item.quote }}</p>
          <button
            type="button"
            class="testimonial-card__expand"
            hidden
            data-testimonial-open
            data-testimonial-index="{{ loop.index0 }}"
            data-i18n="ui.readFullReview"
          >
            Виж целия отзив
          </button>
          <p class="testimonial-card__name">– <span data-i18n="home.testimonials.items.{{ loop.index0 }}.name">{{ item.name }}</span></p>
        </article>
        {% endfor %}
      </div>
      <div class="testimonials-strip-set" aria-hidden="true">
        {% for item in items %}
        <article class="testimonial-card" data-testimonial-index="{{ loop.index0 }}">
          <div class="testimonial-card__stars" aria-hidden="true">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
          <p class="testimonial-card__quote" data-i18n="home.testimonials.items.{{ loop.index0 }}.quote">{{ item.quote }}</p>
          <button
            type="button"
            class="testimonial-card__expand"
            hidden
            data-testimonial-open
            data-testimonial-index="{{ loop.index0 }}"
            data-i18n="ui.readFullReview"
          >
            Виж целия отзив
          </button>
          <p class="testimonial-card__name">– <span data-i18n="home.testimonials.items.{{ loop.index0 }}.name">{{ item.name }}</span></p>
        </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  window.ValetoTestimonialsData = {{ items | dump | safe }};
</script>
<script src="{{ '/assets/js/testimonials-strip.js' | url }}"></script>
{% endif %}
