{% set cs = home.clientsSection if home and home.clientsSection else {} %}
<section
  id="clients"
  class="mb-section clients-section section-padding"
  aria-labelledby="clients-heading"
>
  <div class="container-custom relative">
    <header class="mb-header text-center mx-auto mb-10">
      <span class="mb-eyebrow justify-center">Резултати</span>
      <h2 id="clients-heading" class="mb-title text-center mt-2">
        Преди / След
      </h2>
      {% if cs.lead %}
      <p class="site-lead mt-3 text-center opacity-80">
        {{ cs.lead }}
      </p>
      {% endif %}
    </header>
  </div>

  {% if clients and clients.length %}
  <div class="clients-wrap" data-clients-wrap>
    <!-- Auto-moving draggable strip -->
    <div class="clients-strip-wrapper">
      <div class="clients-strip" role="list" data-clients-strip>
        <div class="clients-strip-set">
        {% for client in clients %}
        <div
          class="client-card"
          data-client-id="{{ client.id }}"
        >
          <div class="client-card__visual">
            <div class="client-card__half">
              <img src="{{ client.beforeImage | url }}" alt="{{ client.name }} преди" class="client-card__img" loading="lazy" decoding="async" draggable="false">
              <span class="client-card__label">Преди</span>
            </div>
            <div class="client-card__half">
              <img src="{{ client.afterImage | url }}" alt="{{ client.name }} след" class="client-card__img" loading="lazy" decoding="async" draggable="false">
              <span class="client-card__label">След</span>
            </div>
          </div>
          <button
            type="button"
            class="client-card__btn-below"
            data-client-trigger
            data-client-id="{{ client.id }}"
            aria-label="Виж повече за {{ client.name }}"
          >
            Виж повече
          </button>
          {% if client.services and client.services.length %}
          <p class="client-card__procedure" aria-label="Процедура">
            {% for svc in client.services %}
            <span class="client-card__procedure-item">{{ svc }}</span>{% if not loop.last %}<span class="client-card__procedure-sep" aria-hidden="true">·</span>{% endif %}
            {% endfor %}
          </p>
          {% endif %}
        </div>
        {% endfor %}
        </div>
        <div class="clients-strip-set" aria-hidden="true">
        {% for client in clients %}
        <div class="client-card" data-client-id="{{ client.id }}">
          <div class="client-card__visual">
            <div class="client-card__half">
              <img src="{{ client.beforeImage | url }}" alt="" class="client-card__img" loading="lazy" decoding="async" draggable="false">
              <span class="client-card__label">Преди</span>
            </div>
            <div class="client-card__half">
              <img src="{{ client.afterImage | url }}" alt="" class="client-card__img" loading="lazy" decoding="async" draggable="false">
              <span class="client-card__label">След</span>
            </div>
          </div>
          <button
            type="button"
            class="client-card__btn-below"
            data-client-trigger
            data-client-id="{{ client.id }}"
            aria-label="Виж повече за {{ client.name }}"
          >
            Виж повече
          </button>
          {% if client.services and client.services.length %}
          <p class="client-card__procedure" aria-label="Процедура">
            {% for svc in client.services %}
            <span class="client-card__procedure-item">{{ svc }}</span>{% if not loop.last %}<span class="client-card__procedure-sep" aria-hidden="true">·</span>{% endif %}
            {% endfor %}
          </p>
          {% endif %}
        </div>
        {% endfor %}
        </div>
      </div>
    </div>
  </div>
  {% else %}
  <div class="container-custom">
    <p class="mx-auto max-w-2xl text-center text-[#5a483e]">
      {{ cs.emptyNote | default("Скоро тук ще има реални истории и снимки от клиенти.") }}
    </p>
  </div>
  {% endif %}

</section>

<!-- Injecting the JSON data into window object for quick JS access -->
<script>
  window.ValetoClientsData = {{ clients | dump | safe }};
</script>

<script>
  (function initClients() {
    // 1. Auto-moving infinite carousel + drag (same behavior as testimonials strip)
    var strip = document.querySelector("[data-clients-strip]");
    var setEl = strip ? strip.querySelector(".clients-strip-set") : null;
    var setWidth = 0;
    var loopWidth = 0;
    var position = 0;
    var dragging = false;
    var touchPending = false;
    var startX = 0;
    var startY = 0;
    var startPos = 0;
    var speed = 0.15;
    var AXIS_LOCK_PX = 10;

    function getStripGap() {
      if (!strip) return 0;
      var cs = getComputedStyle(strip);
      return parseFloat(cs.columnGap || cs.gap || "0") || 0;
    }

    function ensureSetMinWidth() {
      if (!strip) return;
      var sets = strip.querySelectorAll(".clients-strip-set");
      if (!sets.length) return;

      var minSetWidth = strip.clientWidth + getStripGap() + 1;
      sets.forEach(function (set) {
        if (!set.dataset.baseHtml) {
          set.dataset.baseHtml = set.innerHTML;
        }
        // Always rebuild from the original markup to avoid clone accumulation on re-run/resize.
        set.innerHTML = set.dataset.baseHtml;

        var originals = Array.prototype.slice.call(set.children);
        if (!originals.length) return;

        var idx = 0;
        while (set.scrollWidth < minSetWidth && idx < 80) {
          var clone = originals[idx % originals.length].cloneNode(true);
          set.appendChild(clone);
          idx += 1;
        }

        // Keep each set internally non-duplicating at the wrap boundary:
        // if it ends on the same card it starts with, append the next base card.
        if (originals.length > 1) {
          var firstId = originals[0].getAttribute("data-client-id");
          var lastEl = set.lastElementChild;
          var lastId = lastEl ? lastEl.getAttribute("data-client-id") : null;
          if (firstId && lastId && firstId === lastId) {
            set.appendChild(originals[1].cloneNode(true));
          }
        }
      });
    }

    function refreshMeasurements() {
      if (!setEl) return;
      setWidth = setEl.offsetWidth;
      loopWidth = setWidth + getStripGap();
    }

    function getClientX(e) {
      return e.touches ? e.touches[0].clientX : e.clientX;
    }

    function getClientY(e) {
      return e.touches ? e.touches[0].clientY : e.clientY;
    }

    function tick() {
      if (!strip || !loopWidth) return;
      if (!dragging && !touchPending) {
        position -= speed;
        if (position < -loopWidth) position += loopWidth;
        if (position > 0) position -= loopWidth;
      }
      strip.style.transform = "translateX(" + position + "px)";
      requestAnimationFrame(tick);
    }

    function onDown(e) {
      if (e.target.closest("[data-client-trigger]")) return;
      if (typeof e.button === "number" && e.button !== 0 && !e.touches) return;

      startX = getClientX(e);
      startY = getClientY(e);
      startPos = position;

      if (e.touches) {
        touchPending = true;
        dragging = false;
        return;
      }

      if (e.cancelable) e.preventDefault();
      dragging = true;
      strip.classList.add("is-dragging");
      strip.style.cursor = "grabbing";
    }

    function onMove(e) {
      if (touchPending && !dragging) {
        var x = getClientX(e);
        var y = getClientY(e);
        var dx = Math.abs(x - startX);
        var dy = Math.abs(y - startY);
        if (dx < AXIS_LOCK_PX && dy < AXIS_LOCK_PX) return;
        if (dy >= dx) {
          touchPending = false;
          return;
        }
        touchPending = false;
        dragging = true;
        strip.classList.add("is-dragging");
      }

      if (!dragging) return;
      var moveX = getClientX(e);
      position = startPos + (moveX - startX);
    }

    function onUp() {
      touchPending = false;
      dragging = false;
      if (strip) strip.classList.remove("is-dragging");
      if (strip) strip.style.cursor = "";
      while (position < -loopWidth) position += loopWidth;
      while (position > 0) position -= loopWidth;
    }

    if (strip && setEl) {
      ensureSetMinWidth();
      refreshMeasurements();
      strip.style.willChange = "transform";
      strip.addEventListener("dragstart", function (e) {
        e.preventDefault();
      });
      strip.addEventListener("mousedown", onDown);
      strip.addEventListener("touchstart", onDown, { passive: true });
      window.addEventListener("mousemove", onMove);
      window.addEventListener("touchmove", onMove, { passive: true });
      window.addEventListener("mouseup", onUp);
      window.addEventListener("touchend", onUp);
      window.addEventListener("touchcancel", onUp);

      if (loopWidth > 0) requestAnimationFrame(tick);
      else window.addEventListener("load", function () {
        refreshMeasurements();
        requestAnimationFrame(tick);
      });
    }

    // 2. Navigation Arrows
    var prevBtn = document.querySelector("[data-clients-prev]");
    var nextBtn = document.querySelector("[data-clients-next]");
    
    function cardWidth() {
      var card = document.querySelector(".client-card");
      if (!strip) return 0;
      if (!card) return strip.clientWidth * 0.8;
      var cs = getComputedStyle(setEl || strip);
      var gap = parseFloat(cs.columnGap || cs.gap || "0") || 0;
      return card.getBoundingClientRect().width + gap;
    }

    function updateArrows() {
      if (!prevBtn || !nextBtn) return;
      // Infinite carousel never reaches a hard edge.
      prevBtn.removeAttribute("disabled");
      nextBtn.removeAttribute("disabled");
    }
    
    if (prevBtn) prevBtn.addEventListener("click", function() {
      if (!loopWidth) return;
      position += cardWidth();
      while (position > 0) position -= loopWidth;
    });
    if (nextBtn) nextBtn.addEventListener("click", function() {
      if (!loopWidth) return;
      position -= cardWidth();
      while (position < -loopWidth) position += loopWidth;
    });
    
    if (strip) {
      window.addEventListener("resize", function() {
        ensureSetMinWidth();
        refreshMeasurements();
        updateArrows();
      });
      updateArrows();
    }

    /*
     * Client detail modal + lightbox removed from markup for now.
     * Data stays in window.ValetoClientsData; "Виж повече" buttons are CSS-hidden.
     * To restore: add #client-detail-modal + #clients-lightbox from git history and re-enable block below.
     */
    var modal = document.getElementById("client-detail-modal");
    if (modal && window.ValetoClientsData) {
      var triggers = document.querySelectorAll("button[data-client-trigger]");
      var closes = document.querySelectorAll("[data-client-close]");
      var domName = document.getElementById("client-modal-name");
      var domProcedure = document.getElementById("client-modal-procedure");
      var domBefore = document.getElementById("client-modal-before");
      var domAfter = document.getElementById("client-modal-after");
      var triggerBefore = document.getElementById("lightbox-trigger-before");
      var triggerAfter = document.getElementById("lightbox-trigger-after");
      var lightbox = document.getElementById("clients-lightbox");
      var lightboxImg = document.getElementById("clients-lightbox-img");
      var lightboxCloses = document.querySelectorAll("[data-lightbox-close]");

      function openLightbox(src, altText) {
        if (!lightbox || !lightboxImg || !src) return;
        lightboxImg.src = src;
        lightboxImg.alt = altText || "";
        lightbox.style.display = "grid";
        lightbox.setAttribute("aria-hidden", "false");
      }
      function closeLightbox() {
        if (!lightbox || !lightboxImg) return;
        lightbox.style.display = "none";
        lightbox.setAttribute("aria-hidden", "true");
        lightboxImg.src = "";
        lightboxImg.alt = "";
      }

      if (triggerBefore && domBefore) {
        triggerBefore.addEventListener("click", function () {
          openLightbox(domBefore.src, domBefore.alt || "Преди");
        });
      }
      if (triggerAfter && domAfter) {
        triggerAfter.addEventListener("click", function () {
          openLightbox(domAfter.src, domAfter.alt || "След");
        });
      }

      lightboxCloses.forEach(function (btn) {
        btn.addEventListener("click", closeLightbox);
      });

      function escapeHtml(str) {
        if (!str) return "";
        var d = document.createElement("div");
        d.textContent = str;
        return d.innerHTML;
      }

      function openModal(clientId) {
        var client = window.ValetoClientsData.find(function (c) {
          return c.id === clientId;
        });
        if (!client || !domName || !domProcedure || !domBefore || !domAfter) return;

        domName.textContent = client.name;

        var procHtml = "";
        if (client.services && client.services.length) {
          client.services.forEach(function (svc) {
            procHtml +=
              '<span class="client-modal__proc-chip">' +
              escapeHtml(svc) +
              "</span>";
          });
        }
        domProcedure.innerHTML = procHtml;

        domBefore.src = client.beforeImage;
        domBefore.alt = client.name ? client.name + " — преди" : "Преди";
        domAfter.src = client.afterImage;
        domAfter.alt = client.name ? client.name + " — след" : "След";

        modal.style.display = "grid";
        modal.setAttribute("aria-hidden", "false");
        document.body.classList.add("modal-open");
      }

      function closeModal() {
        modal.style.display = "none";
        modal.setAttribute("aria-hidden", "true");
        document.body.classList.remove("modal-open");
      }

      triggers.forEach(function (btn) {
        btn.addEventListener("click", function (e) {
          e.preventDefault();
          e.stopPropagation();
          openModal(btn.getAttribute("data-client-id"));
        });
      });

      closes.forEach(function (btn) {
        btn.addEventListener("click", closeModal);
      });

      document.addEventListener("keydown", function (e) {
        if (e.key !== "Escape") return;
        if (lightbox && lightbox.style.display !== "none") {
          closeLightbox();
        } else if (modal.style.display !== "none") {
          closeModal();
        }
      });
    }

  })();
</script>
