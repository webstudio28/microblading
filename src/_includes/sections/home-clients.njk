<section
  id="clients"
  class="mb-section clients-section scroll-mt-20 section-padding"
  aria-labelledby="clients-heading"
>
  <div class="container-custom relative">
    <header class="mb-header text-center mx-auto mb-10">
      <span class="mb-eyebrow justify-center">Резултати</span>
      <h2 id="clients-heading" class="mb-title text-center mt-2">
        Моите клиенти
      </h2>
      <p class="site-lead mt-3 text-center opacity-80">
        Усмивките и увереността, които постигнахме заедно. Разгледайте историите и трансформациите на моите клиенти.
      </p>
    </header>
  </div>

  {% if clients and clients.length %}
  <div class="clients-wrap" data-clients-wrap>
    <div class="container-custom">
      <div class="mb-bubbles-head justify-end mb-4">
        <div class="mb-bubbles-nav" aria-hidden="true">
          <button
            type="button"
            class="mb-bubbles-arrow mb-bubbles-arrow--prev"
            data-clients-prev
            aria-label="Предишен клиент"
          >
            <svg class="mb-arrow-icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="21 8 12 16 21 24" vector-effect="non-scaling-stroke" />
            </svg>
          </button>
          <button
            type="button"
            class="mb-bubbles-arrow mb-bubbles-arrow--next"
            data-clients-next
            aria-label="Следващ клиент"
          >
            <svg class="mb-arrow-icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="11 8 20 16 11 24" vector-effect="non-scaling-stroke" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Auto-moving draggable strip -->
    <div class="clients-strip-wrapper">
      <div class="clients-strip" role="list" data-clients-strip>
        <div class="clients-strip-set">
        {% for client in clients %}
        <div
          class="client-card group"
          data-client-id="{{ client.id }}"
        >
          <div class="client-card__visual">
            <img src="{{ client.afterImage }}" alt="{{ client.name }} резултат" class="client-card__img" loading="lazy" decoding="async">

            <div class="client-card__overlay">
              <button
                type="button"
                class="client-card__btn border-0"
                data-client-trigger
                data-client-id="{{ client.id }}"
                aria-label="Виж повече за {{ client.name }}"
              >
                Виж повече
              </button>
            </div>
          </div>

          <div class="client-card__body">
            <div class="flex items-center gap-3 mb-3">
              <img src="{{ client.avatar }}" alt="{{ client.name }}" class="w-10 h-10 rounded-full object-cover shadow-sm bg-white border border-[#2c1a0e]/10">
              <div>
                <h3 class="font-sans text-[11px] font-bold text-[#2c1a0e] uppercase tracking-[0.1em] leading-tight">{{ client.name }}</h3>
                <div class="mt-1.5 flex flex-wrap gap-1.5">
                  {% for svc in client.services %}
                  <span class="inline-flex px-2 py-0.5 bg-[#2c1a0e]/5 text-[#a07850] text-[10px] font-semibold tracking-wide rounded-full border border-[#2c1a0e]/10">
                    {{ svc }}
                  </span>
                  {% endfor %}
                </div>
              </div>
            </div>
            {% if client.review %}
            <p class="text-xs text-[#7a6558] italic line-clamp-2 leading-relaxed">
              {{ client.review }}
            </p>
            {% endif %}
          </div>
        </div>
        {% endfor %}
        </div>
        <div class="clients-strip-set" aria-hidden="true">
        {% for client in clients %}
        <div class="client-card group" data-client-id="{{ client.id }}">
          <div class="client-card__visual">
            <img src="{{ client.afterImage }}" alt="" class="client-card__img" loading="lazy" decoding="async">
            <div class="client-card__overlay">
              <button
                type="button"
                class="client-card__btn border-0"
                data-client-trigger
                data-client-id="{{ client.id }}"
                aria-label="Виж повече за {{ client.name }}"
              >
                Виж повече
              </button>
            </div>
          </div>
          <div class="client-card__body">
            <div class="flex items-center gap-3 mb-3">
              <img src="{{ client.avatar }}" alt="" class="w-10 h-10 rounded-full object-cover shadow-sm bg-white border border-[#2c1a0e]/10">
              <div>
                <h3 class="font-sans text-[11px] font-bold text-[#2c1a0e] uppercase tracking-[0.1em] leading-tight">{{ client.name }}</h3>
                <div class="mt-1.5 flex flex-wrap gap-1.5">
                  {% for svc in client.services %}
                  <span class="inline-flex px-2 py-0.5 bg-[#2c1a0e]/5 text-[#a07850] text-[10px] font-semibold tracking-wide rounded-full border border-[#2c1a0e]/10">
                    {{ svc }}
                  </span>
                  {% endfor %}
                </div>
              </div>
            </div>
            {% if client.review %}
            <p class="text-xs text-[#7a6558] italic line-clamp-2 leading-relaxed">
              {{ client.review }}
            </p>
            {% endif %}
          </div>
        </div>
        {% endfor %}
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  <!-- The Modal Template -->
  <div
    id="client-detail-modal"
    class="client-modal"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby="client-modal-name"
    style="display: none;"
  >
    <div class="client-modal__backdrop" data-client-close></div>
    
    <div class="client-modal__panel" role="document">
      <button
        type="button"
        class="client-modal__close"
        data-client-close
        aria-label="Затвори"
      >
        &times;
      </button>

      <!-- Dynamically populated content -->
      <div class="client-modal__content flex flex-col-reverse md:flex-row h-full md:items-stretch">
        
        <!-- Left: Image comparison (Bottom on mobile) -->
        <div class="client-modal__visuals md:w-3/5 relative flex flex-col md:flex-row">
          
          <!-- Before Image -->
          <div id="lightbox-trigger-before" class="relative w-full h-56 md:h-full md:flex-1 group cursor-zoom-in hover:opacity-95 transition-opacity">
            <img id="client-modal-before" src="" class="w-full h-full object-cover block">
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/60 to-transparent p-4 pointer-events-none">
              <span class="text-white text-xs font-medium uppercase tracking-widest bg-black/40 px-3 py-1 rounded-full backdrop-blur-sm shadow-sm">Преди</span>
            </div>
          </div>
          
          <!-- Separator Line (desktop only, optional visual cue) -->
          <div class="hidden md:block w-1 h-full bg-white/20 z-10 shrink-0"></div>

          <!-- After Image -->
          <div id="lightbox-trigger-after" class="relative w-full h-64 md:h-full md:flex-1 cursor-zoom-in hover:opacity-95 transition-opacity">
            <img id="client-modal-after" src="" class="w-full h-full object-cover block">
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/60 to-transparent p-4 pointer-events-none">
              <span class="text-white text-xs font-medium uppercase tracking-widest bg-black/40 px-3 py-1 rounded-full backdrop-blur-sm shadow-sm">След</span>
            </div>
          </div>
        </div>

        <!-- Right: Text Content -->
        <div class="client-modal__text md:w-2/5 p-6 pt-14 md:p-8 flex flex-col bg-white">
          <div class="flex items-center gap-4 mb-6 pb-6">
            <img id="client-modal-avatar" src="" class="w-16 h-16 rounded-full object-cover shadow-sm bg-white">
            <div>
              <h3 id="client-modal-name" class="font-mak text-2xl text-[#2c1a0e] leading-tight mb-1">Име</h3>
              <div id="client-modal-service" class="flex flex-wrap gap-1.5 mt-2"></div>
            </div>
          </div>
          
          <div class="prose prose-sm prose-[#7a6558] max-w-none mb-8 pb-8">
            <p id="client-modal-desc" class="text-base leading-relaxed text-[#5a483e]"></p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- Lightbox Modal -->
  <div
    id="clients-lightbox"
    class="clients-lightbox"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    style="display: none;"
  >
    <div class="clients-lightbox__backdrop" data-lightbox-close></div>
    <button type="button" class="clients-lightbox__close" data-lightbox-close>&times;</button>
    <img id="clients-lightbox-img" src="" class="clients-lightbox__img">
  </div>
</section>

<!-- Injecting the JSON data into window object for quick JS access -->
<script>
  window.ValetoClientsData = {{ clients | dump | safe }};
</script>

<script>
  (function initClients() {
    // 1. Auto-moving infinite carousel + drag (same behavior as testimonials strip)
    var strip = document.querySelector("[data-clients-strip]");
    var setEl = strip ? strip.querySelector(".clients-strip-set") : null;
    var setWidth = 0;
    var loopWidth = 0;
    var position = 0;
    var dragging = false;
    var startX = 0;
    var startPos = 0;
    var speed = 0.15;

    function getStripGap() {
      if (!strip) return 0;
      var cs = getComputedStyle(strip);
      return parseFloat(cs.columnGap || cs.gap || "0") || 0;
    }

    function ensureSetMinWidth() {
      if (!strip) return;
      var sets = strip.querySelectorAll(".clients-strip-set");
      if (!sets.length) return;

      var minSetWidth = strip.clientWidth + getStripGap() + 1;
      sets.forEach(function (set) {
        if (!set.dataset.baseHtml) {
          set.dataset.baseHtml = set.innerHTML;
        }
        // Always rebuild from the original markup to avoid clone accumulation on re-run/resize.
        set.innerHTML = set.dataset.baseHtml;

        var originals = Array.prototype.slice.call(set.children);
        if (!originals.length) return;

        var idx = 0;
        while (set.scrollWidth < minSetWidth && idx < 80) {
          var clone = originals[idx % originals.length].cloneNode(true);
          set.appendChild(clone);
          idx += 1;
        }

        // Keep each set internally non-duplicating at the wrap boundary:
        // if it ends on the same card it starts with, append the next base card.
        if (originals.length > 1) {
          var firstId = originals[0].getAttribute("data-client-id");
          var lastEl = set.lastElementChild;
          var lastId = lastEl ? lastEl.getAttribute("data-client-id") : null;
          if (firstId && lastId && firstId === lastId) {
            set.appendChild(originals[1].cloneNode(true));
          }
        }
      });
    }

    function refreshMeasurements() {
      if (!setEl) return;
      setWidth = setEl.offsetWidth;
      loopWidth = setWidth + getStripGap();
    }

    function getClientX(e) {
      return e.touches ? e.touches[0].clientX : e.clientX;
    }

    function tick() {
      if (!strip || !loopWidth) return;
      if (!dragging) {
        position -= speed;
        if (position < -loopWidth) position += loopWidth;
        if (position > 0) position -= loopWidth;
      }
      strip.style.transform = "translateX(" + position + "px)";
      requestAnimationFrame(tick);
    }

    function onDown(e) {
      dragging = true;
      startX = getClientX(e);
      startPos = position;
      strip.classList.add("is-dragging");
      strip.style.cursor = "grabbing";
    }

    function onMove(e) {
      if (!dragging) return;
      var x = getClientX(e);
      position = startPos + (x - startX);
    }

    function onUp() {
      dragging = false;
      if (strip) strip.classList.remove("is-dragging");
      if (strip) strip.style.cursor = "";
      while (position < -loopWidth) position += loopWidth;
      while (position > 0) position -= loopWidth;
    }

    if (strip && setEl) {
      ensureSetMinWidth();
      refreshMeasurements();
      strip.style.willChange = "transform";
      strip.addEventListener("mousedown", onDown);
      strip.addEventListener("touchstart", onDown, { passive: true });
      window.addEventListener("mousemove", onMove);
      window.addEventListener("touchmove", onMove, { passive: true });
      window.addEventListener("mouseup", onUp);
      window.addEventListener("touchend", onUp);

      if (loopWidth > 0) requestAnimationFrame(tick);
      else window.addEventListener("load", function () {
        refreshMeasurements();
        requestAnimationFrame(tick);
      });
    }

    // 2. Navigation Arrows
    var prevBtn = document.querySelector("[data-clients-prev]");
    var nextBtn = document.querySelector("[data-clients-next]");
    
    function cardWidth() {
      var card = document.querySelector(".client-card");
      if (!strip) return 0;
      if (!card) return strip.clientWidth * 0.8;
      var cs = getComputedStyle(setEl || strip);
      var gap = parseFloat(cs.columnGap || cs.gap || "0") || 0;
      return card.getBoundingClientRect().width + gap;
    }

    function updateArrows() {
      if (!prevBtn || !nextBtn) return;
      // Infinite carousel never reaches a hard edge.
      prevBtn.removeAttribute("disabled");
      nextBtn.removeAttribute("disabled");
    }
    
    if (prevBtn) prevBtn.addEventListener("click", function() {
      if (!loopWidth) return;
      position += cardWidth();
      while (position > 0) position -= loopWidth;
    });
    if (nextBtn) nextBtn.addEventListener("click", function() {
      if (!loopWidth) return;
      position -= cardWidth();
      while (position < -loopWidth) position += loopWidth;
    });
    
    if (strip) {
      window.addEventListener("resize", function() {
        ensureSetMinWidth();
        refreshMeasurements();
        updateArrows();
      });
      updateArrows();
    }

    // 3. Modal Logic
    var modal = document.getElementById("client-detail-modal");
    var triggers = document.querySelectorAll("button[data-client-trigger]");
    var closes = document.querySelectorAll("[data-client-close]");
    
    if (modal && window.ValetoClientsData) {
      var domName = document.getElementById("client-modal-name");
      var domService = document.getElementById("client-modal-service");
      var domDesc = document.getElementById("client-modal-desc");
      var domAvatar = document.getElementById("client-modal-avatar");
      var domBefore = document.getElementById("client-modal-before");
      var domAfter = document.getElementById("client-modal-after");

      var triggerBefore = document.getElementById("lightbox-trigger-before");
      var triggerAfter = document.getElementById("lightbox-trigger-after");
      var lightbox = document.getElementById("clients-lightbox");
      var lightboxImg = document.getElementById("clients-lightbox-img");
      var lightboxCloses = document.querySelectorAll("[data-lightbox-close]");

      // Lightbox logic
      function openLightbox(src) {
        if (!src) return;
        lightboxImg.src = src;
        lightbox.style.display = "grid";
        lightbox.setAttribute("aria-hidden", "false");
      }
      function closeLightbox() {
        lightbox.style.display = "none";
        lightbox.setAttribute("aria-hidden", "true");
        lightboxImg.src = "";
      }
      
      triggerBefore.addEventListener("click", function() { openLightbox(domBefore.src); });
      triggerAfter.addEventListener("click", function() { openLightbox(domAfter.src); });
      
      lightboxCloses.forEach(function(btn) {
        btn.addEventListener("click", closeLightbox);
      });

      function openModal(clientId) {
        var client = window.ValetoClientsData.find(c => c.id === clientId);
        if (!client) return;

        domName.textContent = client.name;
        
        var servicesHtml = "";
        if (client.services && client.services.length) {
          client.services.forEach(function(svc) {
            servicesHtml += '<span class="inline-flex px-2 py-0.5 bg-[#2c1a0e]/5 text-[#a07850] text-[10px] font-semibold tracking-wide rounded-full border border-[#2c1a0e]/10">' + svc + '</span>';
          });
        }
        domService.innerHTML = servicesHtml;
        
        domDesc.textContent = client.description;
        domAvatar.src = client.avatar;
        domBefore.src = client.beforeImage;
        domAfter.src = client.afterImage;

        modal.style.display = "grid";
        modal.setAttribute("aria-hidden", "false");
        document.body.classList.add("modal-open");
      }

      function closeModal() {
        modal.style.display = "none";
        modal.setAttribute("aria-hidden", "true");
        document.body.classList.remove("modal-open");
      }

      triggers.forEach(function (btn) {
        btn.addEventListener("click", function (e) {
          e.preventDefault();
          e.stopPropagation();
          openModal(this.getAttribute("data-client-id"));
        });
      });

      closes.forEach(function(btn) {
        btn.addEventListener("click", closeModal);
      });

      document.addEventListener("keydown", function(e) {
        if (e.key === "Escape") {
          if (lightbox && lightbox.style.display !== "none") {
            closeLightbox();
          } else if (modal.style.display !== "none") {
            closeModal();
          }
        }
      });
    }

  })();
</script>
