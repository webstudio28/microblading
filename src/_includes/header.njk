{% set headerCta = home.hero.ctaPrimary if home and home.hero and home.hero.ctaPrimary else { "label": "Запази час", "url": "#contact" } %}
<header class="sticky top-4 z-50">
  <div class="container-custom">
    <div class="site-header-surface js-header-surface">

      {# Logo #}
      <a href="{{ '/' | url }}" class="shrink-0" aria-label="{% if site and site.brand %}{{ site.brand.logoAlt | default(site.brand.name) }}{% else %}Home{% endif %}">
        {% if site and site.brand and site.brand.logo %}
          <img
            src="{{ site.brand.logo | url }}"
            alt="{{ site.brand.logoAlt | default(site.brand.name) }}"
            class="h-10 w-auto"
            width="120" height="40"
            fetchpriority="high"
          >
        {% else %}
          <span class="text-ink font-semibold text-lg">{{ site.brand.name | default("Valeto") }}</span>
        {% endif %}
      </a>

      {# Nav — centered against full header width #}
      <nav class="absolute left-1/2 top-1/2 hidden -translate-x-1/2 -translate-y-1/2 items-center justify-center gap-3 whitespace-nowrap md:flex md:gap-5 xl:gap-8" aria-label="Main">
        {% for item in site.nav.header %}
          <a
            href="{{ item.url }}"
            class="shrink-0 text-[14px] font-medium leading-snug text-[#4a3728] hover:text-brand-primary transition-colors duration-150"
          >{{ item.label }}</a>
        {% endfor %}
      </nav>

      <button
        type="button"
        class="mobile-menu-toggle md:hidden"
        id="mobile-menu-toggle"
        aria-label="Отвори меню"
        aria-expanded="false"
        aria-controls="mobile-menu-panel"
      >
        <span class="mobile-menu-toggle__line"></span>
        <span class="mobile-menu-toggle__line"></span>
        <span class="mobile-menu-toggle__line"></span>
      </button>

      <a
        href="{{ headerCta.url }}"
        class="header-book-cta hidden md:inline-flex"
        data-booking-open
        aria-haspopup="dialog"
        aria-controls="booking-modal"
      >{{ headerCta.label }}</a>

    </div>
  </div>
</header>

<div
  id="mobile-menu-backdrop"
  class="mobile-menu-backdrop"
  aria-hidden="true"
  hidden
></div>

<aside
  id="mobile-menu-panel"
  class="mobile-menu-panel"
  aria-hidden="true"
  hidden
>
  <div class="mobile-menu-panel__inner">
    <button
      type="button"
      class="mobile-menu-close"
      id="mobile-menu-close"
      aria-label="Затвори меню"
    >
      &times;
    </button>

    <nav class="mobile-menu-nav" aria-label="Mobile">
      {% for item in site.nav.header %}
        <a href="{{ item.url }}" class="mobile-menu-link">{{ item.label }}</a>
      {% endfor %}

      <a
        href="{{ headerCta.url }}"
        class="mobile-menu-link mobile-menu-link--cta"
        data-booking-open
        aria-haspopup="dialog"
        aria-controls="booking-modal"
      >{{ headerCta.label }}</a>
    </nav>
  </div>
</aside>
