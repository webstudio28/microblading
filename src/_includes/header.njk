{% set headerCta = home.hero.ctaPrimary if home and home.hero and home.hero.ctaPrimary else { "label": "Запази час", "url": "#contact" } %}
<header class="sticky top-4 z-50">
  <div class="container-custom">
    <div class="site-header-surface">

      {# Logo #}
      <a href="{{ '/' | url }}" class="shrink-0" aria-label="{% if site and site.brand %}{{ site.brand.logoAlt | default(site.brand.name) }}{% else %}Home{% endif %}">
        {% if site and site.brand and site.brand.logo %}
          <img
            src="{{ site.brand.logo | url }}"
            alt="{{ site.brand.logoAlt | default(site.brand.name) }}"
            class="h-10 w-auto"
            width="120" height="40"
            fetchpriority="high"
          >
        {% else %}
          <span class="text-ink font-semibold text-lg">{{ site.brand.name | default("Valeto") }}</span>
        {% endif %}
      </a>

      <div class="flex min-w-0 flex-1 items-center justify-end gap-3 sm:gap-4 lg:gap-6">
        {# Nav #}
        <nav class="flex min-w-0 items-center gap-3 overflow-x-auto whitespace-nowrap sm:gap-5 xl:gap-8" aria-label="Main">
          {% for item in site.nav.header %}
            <a
              href="{{ item.url }}"
              class="text-[13px] font-medium text-[#4a3728] hover:text-brand-primary transition-colors duration-150"
            >{{ item.label }}</a>
          {% endfor %}
        </nav>

        <a
          href="{{ headerCta.url }}"
          class="header-book-cta"
        >{{ headerCta.label }}</a>
      </div>

    </div>
  </div>
</header>
