<!DOCTYPE html>
<html lang="{% if site and site.brand %}{{ site.brand.language }}{% else %}en{% endif %}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }}{% elif site and site.seo %}{{ site.seo.defaultTitle }}{% else %}Valeto{% endif %}</title>
  <meta name="description" content="{% if description %}{{ description }}{% elif site and site.seo %}{{ site.seo.defaultDescription }}{% endif %}">
  {% if site and site.seo and site.seo.siteUrl %}
  <link rel="canonical" href="{{ site.seo.siteUrl }}{{ page.url | url }}">
  {% endif %}

  <meta name="theme-color" content="{% if site and site.colors %}{{ site.colors.primary }}{% else %}#0f172a{% endif %}">

  <style>
    :root{
      --color-brand-primary: {% if site and site.colors %}{{ site.colors.primary }}{% else %}#2563eb{% endif %};
      --color-brand-secondary: {% if site and site.colors %}{{ site.colors.secondary }}{% else %}#64748b{% endif %};
      --color-brand-accent: {% if site and site.colors %}{{ site.colors.accent }}{% else %}#f59e0b{% endif %};
    }
  </style>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat+Alternates:wght@200;300;400;500&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/assets/css/styles.css' | url }}">
</head>
<body>
  {# Full-page texture overlay — sits above gradient, below all content #}
  <div class="site-bg-overlay" aria-hidden="true"></div>

  <div class="relative z-10">
    {% include "header.njk" %}
    {{ content | safe }}
  </div>

  <div
    id="booking-modal"
    class="booking-modal"
    data-booking-endpoint="{{ home.booking.submitEndpoint if home and home.booking and home.booking.submitEndpoint else '' }}"
    data-booking-cal-url="{{ home.booking.calBookingUrl if home and home.booking and home.booking.calBookingUrl else '' }}"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby="booking-modal-title"
    hidden
  >
    <div class="booking-modal__backdrop" data-booking-close></div>
    <div class="booking-modal__panel" role="document" tabindex="-1">
      <button
        type="button"
        class="booking-modal__close"
        data-booking-close
        aria-label="Затвори модалния прозорец"
      >
        &times;
      </button>
      <h2 id="booking-modal-title" class="booking-modal__title">Запази час</h2>
      <p class="booking-modal__subtitle">Стъпка <span data-booking-step-current>1</span> от 3</p>

      <form class="booking-form" data-booking-form novalidate>
        <div class="booking-step" data-booking-step="0">
          <p class="booking-step__label">Избери услуга</p>
          <div class="booking-service-grid">
            <label class="booking-service-card">
              <input type="radio" name="serviceType" value="microblading" class="booking-service-input">
              <span class="booking-service-text">Микроблейдинг</span>
            </label>
            <label class="booking-service-card">
              <input type="radio" name="serviceType" value="lamination" class="booking-service-input">
              <span class="booking-service-text">Ламиниране</span>
            </label>
          </div>
        </div>

        <div class="booking-step" data-booking-step="1" hidden>
          <p class="booking-step__label">Избери дата и час</p>
          <input name="date" type="hidden" data-booking-selected-date required>
          <input name="time" type="hidden" data-booking-selected-time required>

          <div class="booking-availability">
            <p class="booking-availability__title">Свободни дни</p>
            <div class="booking-day-list" data-booking-day-list></div>
          </div>

          <div class="booking-availability booking-availability--slots">
            <p class="booking-availability__title">Свободни часове</p>
            <div class="booking-slot-list" data-booking-slot-list></div>
          </div>
          <p class="booking-availability__status" data-booking-slot-status></p>
        </div>

        <div class="booking-step" data-booking-step="2" hidden>
          <p class="booking-step__label">Лични данни</p>
          <div class="booking-field-wrap">
            <label class="booking-field-label" for="booking-full-name">Име и фамилия</label>
            <input id="booking-full-name" name="fullName" type="text" class="booking-field-input" required>
          </div>
          <div class="booking-field-wrap">
            <label class="booking-field-label" for="booking-phone">Телефон</label>
            <input id="booking-phone" name="phone" type="tel" class="booking-field-input" required>
          </div>
          <div class="booking-field-wrap">
            <label class="booking-field-label" for="booking-email">Имейл</label>
            <input id="booking-email" name="email" type="email" class="booking-field-input" required>
          </div>

          <details class="booking-debug">
            <summary class="booking-debug__summary">Debug payload preview</summary>
            <p class="booking-debug__meta" data-booking-debug-target></p>
            <pre class="booking-debug__code" data-booking-debug-output></pre>
          </details>
        </div>

        <p class="booking-form__feedback" data-booking-feedback aria-live="polite"></p>

        <div class="booking-form__actions">
          <button type="button" class="booking-btn booking-btn--ghost" data-booking-prev disabled>Назад</button>
          <button type="button" class="booking-btn booking-btn--primary" data-booking-next>Напред</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    (function () {
      var headerSurface = document.querySelector(".js-header-surface");
      if (!headerSurface) return;

      var onScroll = function () {
        if (window.scrollY > 18) {
          headerSurface.classList.add("is-glassy");
        } else {
          headerSurface.classList.remove("is-glassy");
        }
      };

      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });
    })();

    (function () {
      var toggle = document.getElementById("mobile-menu-toggle");
      var panel = document.getElementById("mobile-menu-panel");
      var backdrop = document.getElementById("mobile-menu-backdrop");
      var closeBtn = document.getElementById("mobile-menu-close");
      if (!toggle || !panel || !backdrop) return;

      var mobileLinks = panel.querySelectorAll(".mobile-menu-link");
      var isOpen = false;
      var closeTimer = null;

      var openMenu = function () {
        if (closeTimer) {
          window.clearTimeout(closeTimer);
          closeTimer = null;
        }
        isOpen = true;
        toggle.classList.add("is-active");
        toggle.setAttribute("aria-expanded", "true");
        toggle.setAttribute("aria-label", "Затвори меню");
        panel.hidden = false;
        backdrop.hidden = false;
        panel.setAttribute("aria-hidden", "false");
        backdrop.setAttribute("aria-hidden", "false");
        document.body.classList.add("modal-open");

        requestAnimationFrame(function () {
          panel.classList.add("is-open");
          backdrop.classList.add("is-open");
        });
      };

      var closeMenu = function () {
        if (!isOpen) return;
        isOpen = false;
        toggle.classList.remove("is-active");
        toggle.setAttribute("aria-expanded", "false");
        toggle.setAttribute("aria-label", "Отвори меню");
        panel.classList.remove("is-open");
        backdrop.classList.remove("is-open");
        panel.setAttribute("aria-hidden", "true");
        backdrop.setAttribute("aria-hidden", "true");
        document.body.classList.remove("modal-open");

        closeTimer = window.setTimeout(function () {
          panel.hidden = true;
          backdrop.hidden = true;
          closeTimer = null;
        }, 290);
      };

      toggle.addEventListener("click", function () {
        if (isOpen) closeMenu();
        else openMenu();
      });

      if (closeBtn) closeBtn.addEventListener("click", closeMenu);
      backdrop.addEventListener("click", closeMenu);
      mobileLinks.forEach(function (link) {
        link.addEventListener("click", closeMenu);
      });

      document.addEventListener("keydown", function (event) {
        if (event.key === "Escape" && isOpen) closeMenu();
      });
    })();

    (function () {
      var modal = document.getElementById("booking-modal");
      if (!modal) return;

      var openTriggers = Array.prototype.slice.call(
        document.querySelectorAll("[data-booking-open]")
      );
      var closeTriggers = Array.prototype.slice.call(
        modal.querySelectorAll("[data-booking-close]")
      );
      var submitEndpoint = modal.getAttribute("data-booking-endpoint") || "";
      var calBookingUrl = modal.getAttribute("data-booking-cal-url") || "";
      var bookingForm = modal.querySelector("[data-booking-form]");
      var steps = Array.prototype.slice.call(
        modal.querySelectorAll("[data-booking-step]")
      );
      var stepCurrentLabel = modal.querySelector("[data-booking-step-current]");
      var feedbackEl = modal.querySelector("[data-booking-feedback]");
      var prevBtn = modal.querySelector("[data-booking-prev]");
      var nextBtn = modal.querySelector("[data-booking-next]");
      var selectedDateInput = modal.querySelector("[data-booking-selected-date]");
      var selectedTimeInput = modal.querySelector("[data-booking-selected-time]");
      var dayListEl = modal.querySelector("[data-booking-day-list]");
      var slotListEl = modal.querySelector("[data-booking-slot-list]");
      var slotStatusEl = modal.querySelector("[data-booking-slot-status]");
      var debugTargetEl = modal.querySelector("[data-booking-debug-target]");
      var debugOutputEl = modal.querySelector("[data-booking-debug-output]");
      var previousFocusedElement = null;
      var currentStep = 0;
      var isSubmitting = false;
      var isLoadingAvailability = false;
      var availabilityByDay = {};
      var availabilityDays = [];
      var selectedDay = "";
      var selectedSlotIso = "";

      var locale = "bg-BG";
      var userTimeZone = "Europe/Sofia";
      var attendeeLanguage = "bg";
      try {
        if (
          typeof Intl !== "undefined" &&
          Intl.DateTimeFormat &&
          Intl.DateTimeFormat().resolvedOptions().timeZone
        ) {
          userTimeZone = Intl.DateTimeFormat().resolvedOptions().timeZone;
        }
      } catch (error) {
        userTimeZone = "Europe/Sofia";
      }

      var formatDateLabel = function (day) {
        return new Date(day + "T00:00:00").toLocaleDateString(locale, {
          weekday: "short",
          day: "numeric",
          month: "short"
        });
      };

      var formatTimeLabel = function (isoValue) {
        return new Date(isoValue).toLocaleTimeString(locale, {
          hour: "2-digit",
          minute: "2-digit"
        });
      };

      var setFeedback = function (message, kind) {
        if (!feedbackEl) return;
        feedbackEl.textContent = message || "";
        feedbackEl.classList.remove(
          "booking-form__feedback--error",
          "booking-form__feedback--success"
        );
        if (!message) return;
        feedbackEl.classList.add(
          kind === "success"
            ? "booking-form__feedback--success"
            : "booking-form__feedback--error"
        );
      };

      var setSlotStatus = function (message, kind) {
        if (!slotStatusEl) return;
        slotStatusEl.textContent = message || "";
        slotStatusEl.classList.remove(
          "booking-availability__status--error",
          "booking-availability__status--success",
          "booking-availability__status--muted"
        );
        if (!message) return;
        slotStatusEl.classList.add(
          kind === "success"
            ? "booking-availability__status--success"
            : kind === "muted"
              ? "booking-availability__status--muted"
              : "booking-availability__status--error"
        );
      };

      var buildBookingPayload = function () {
        if (!bookingForm) return null;
        var serviceInput = bookingForm.querySelector(
          "input[name='serviceType']:checked"
        );
        var fullNameInput = bookingForm.querySelector("input[name='fullName']");
        var phoneInput = bookingForm.querySelector("input[name='phone']");
        var emailInput = bookingForm.querySelector("input[name='email']");
        var serviceLabels = {
          microblading: "Микроблейдинг",
          lamination: "Ламиниране"
        };

        var serviceValue = serviceInput ? serviceInput.value : "";
        return {
          source: "valeto-site",
          service: serviceValue,
          serviceLabel: serviceLabels[serviceValue] || serviceValue,
          date: selectedDateInput ? selectedDateInput.value : "",
          time: selectedTimeInput ? selectedTimeInput.value : "",
          slotStartIso: selectedSlotIso || "",
          fullName: fullNameInput ? fullNameInput.value.trim() : "",
          phone: phoneInput ? phoneInput.value.trim() : "",
          email: emailInput ? emailInput.value.trim() : "",
          timeZone: userTimeZone,
          language: attendeeLanguage
        };
      };

      var updateDebugPreview = function () {
        if (debugTargetEl) {
          debugTargetEl.textContent = submitEndpoint
            ? "POST " + submitEndpoint
            : "Fallback redirect: " + calBookingUrl;
        }
        if (debugOutputEl) {
          var payload = buildBookingPayload();
          debugOutputEl.textContent = JSON.stringify(payload, null, 2);
        }
      };

      var parseCalBookingConfig = function () {
        if (!calBookingUrl) return null;
        try {
          var parsedUrl = new URL(calBookingUrl);
          var pathParts = parsedUrl.pathname.split("/").filter(Boolean);
          if (pathParts.length < 2) return null;

          var hostName = parsedUrl.hostname || "";
          var apiHost = "api.cal.com";
          if (hostName.indexOf("api.cal.") === 0) {
            apiHost = hostName;
          } else if (hostName.indexOf("cal.") === 0) {
            apiHost = "api." + hostName;
          }

          return {
            eventTypeSlug: pathParts[pathParts.length - 1],
            username: pathParts[pathParts.length - 2],
            apiBaseUrl: parsedUrl.protocol + "//" + apiHost
          };
        } catch (error) {
          return null;
        }
      };

      var clearSelectedDateTime = function () {
        selectedDay = "";
        selectedSlotIso = "";
        if (selectedDateInput) selectedDateInput.value = "";
        if (selectedTimeInput) selectedTimeInput.value = "";
      };

      var renderSlotButtons = function () {
        if (!slotListEl) return;
        slotListEl.innerHTML = "";

        if (!selectedDay || !availabilityByDay[selectedDay]) {
          setSlotStatus("Избери ден, за да видиш часовете.", "muted");
          return;
        }

        var slots = availabilityByDay[selectedDay];
        if (!slots.length) {
          setSlotStatus("Няма свободни часове за този ден.", "muted");
          return;
        }

        slots.forEach(function (slotIso) {
          var btn = document.createElement("button");
          btn.type = "button";
          btn.className = "booking-slot-btn";
          btn.textContent = formatTimeLabel(slotIso);
          btn.setAttribute("data-slot-iso", slotIso);
          if (slotIso === selectedSlotIso) {
            btn.classList.add("is-active");
          }

          btn.addEventListener("click", function () {
            selectedSlotIso = slotIso;
            if (selectedDateInput) {
              selectedDateInput.value = selectedDay;
            }
            if (selectedTimeInput) {
              selectedTimeInput.value = formatTimeLabel(slotIso);
            }
            renderSlotButtons();
            setSlotStatus("Избран час: " + formatTimeLabel(slotIso), "success");
            updateDebugPreview();
          });

          slotListEl.appendChild(btn);
        });

        if (!selectedSlotIso) {
          setSlotStatus("Избери свободен час.", "muted");
        }
      };

      var renderDayButtons = function () {
        if (!dayListEl) return;
        dayListEl.innerHTML = "";

        if (!availabilityDays.length) {
          setSlotStatus("Няма налични дни в избрания период.", "error");
          renderSlotButtons();
          return;
        }

        availabilityDays.forEach(function (day) {
          var btn = document.createElement("button");
          btn.type = "button";
          btn.className = "booking-day-btn";
          btn.textContent = formatDateLabel(day);
          btn.setAttribute("data-day", day);
          if (day === selectedDay) {
            btn.classList.add("is-active");
          }

          btn.addEventListener("click", function () {
            selectedDay = day;
            selectedSlotIso = "";
            if (selectedDateInput) selectedDateInput.value = day;
            if (selectedTimeInput) selectedTimeInput.value = "";
            renderDayButtons();
            renderSlotButtons();
          });

          dayListEl.appendChild(btn);
        });
      };

      var toIsoDate = function (dateObj) {
        var year = dateObj.getFullYear();
        var month = String(dateObj.getMonth() + 1).padStart(2, "0");
        var day = String(dateObj.getDate()).padStart(2, "0");
        return year + "-" + month + "-" + day;
      };

      var loadAvailability = async function () {
        if (isLoadingAvailability) return;

        var parsed = parseCalBookingConfig();
        if (!parsed) {
          setSlotStatus("Добави валиден booking.calBookingUrl за зареждане на слотовете.", "error");
          return;
        }

        isLoadingAvailability = true;
        clearSelectedDateTime();
        availabilityByDay = {};
        availabilityDays = [];
        if (dayListEl) dayListEl.innerHTML = "";
        if (slotListEl) slotListEl.innerHTML = "";
        setSlotStatus("Зареждаме свободните часове...", "muted");

        try {
          var startDate = new Date();
          var endDate = new Date();
          endDate.setDate(startDate.getDate() + 21);

          var apiUrl = new URL("/v2/slots", parsed.apiBaseUrl);
          apiUrl.searchParams.set("eventTypeSlug", parsed.eventTypeSlug);
          apiUrl.searchParams.set("username", parsed.username);
          apiUrl.searchParams.set("start", toIsoDate(startDate));
          apiUrl.searchParams.set("end", toIsoDate(endDate));
          apiUrl.searchParams.set("timeZone", userTimeZone);
          apiUrl.searchParams.set("format", "time");

          var response = await fetch(apiUrl.toString(), {
            headers: {
              "cal-api-version": "2024-09-04"
            }
          });

          if (!response.ok) {
            throw new Error("Slots request failed: " + response.status);
          }

          var result = await response.json();
          var slotsMap = {};

          if (result && result.data) {
            if (result.data.slots && typeof result.data.slots === "object") {
              slotsMap = result.data.slots;
            } else if (typeof result.data === "object") {
              slotsMap = result.data;
            }
          }
          var dayKeys = Object.keys(slotsMap).sort();

          dayKeys.forEach(function (dayKey) {
            var daySlots = slotsMap[dayKey] || [];
            var slotValues = daySlots
              .map(function (slotItem) {
                if (typeof slotItem === "string") return slotItem;
                if (slotItem && slotItem.start) return slotItem.start;
                return "";
              })
              .filter(Boolean);

            if (slotValues.length) {
              availabilityByDay[dayKey] = slotValues;
            }
          });

          availabilityDays = Object.keys(availabilityByDay).sort();
          if (availabilityDays.length) {
            selectedDay = availabilityDays[0];
            if (selectedDateInput) selectedDateInput.value = selectedDay;
          }
          renderDayButtons();
          renderSlotButtons();
        } catch (error) {
          if (dayListEl) dayListEl.innerHTML = "";
          if (slotListEl) slotListEl.innerHTML = "";
          setSlotStatus("Неуспешно зареждане на наличните часове. Опитай отново.", "error");
        } finally {
          isLoadingAvailability = false;
        }
      };

      var focusCurrentStepField = function () {
        if (!steps[currentStep]) return;
        var firstField = steps[currentStep].querySelector(
          "button, input:not([type='hidden']), select, textarea"
        );
        if (firstField && typeof firstField.focus === "function") {
          firstField.focus();
        }
      };

      var renderStep = function () {
        steps.forEach(function (step, index) {
          step.hidden = index !== currentStep;
        });

        if (stepCurrentLabel) {
          stepCurrentLabel.textContent = String(currentStep + 1);
        }

        if (prevBtn) {
          prevBtn.disabled = currentStep === 0 || isSubmitting;
        }

        if (nextBtn) {
          nextBtn.disabled = isSubmitting;
          if (isSubmitting) {
            nextBtn.textContent = "Изпращане...";
          } else {
            nextBtn.textContent = currentStep === steps.length - 1 ? "Изпрати" : "Напред";
          }
        }

        setFeedback("");

        if (currentStep === 1 && calBookingUrl && !availabilityDays.length) {
          loadAvailability();
        }
        updateDebugPreview();
      };

      var setSubmitting = function (value) {
        isSubmitting = value;
        if (prevBtn) {
          prevBtn.disabled = currentStep === 0 || isSubmitting;
        }
        if (nextBtn) {
          nextBtn.disabled = isSubmitting;
          if (isSubmitting) {
            nextBtn.textContent = "Изпращане...";
          } else {
            nextBtn.textContent = currentStep === steps.length - 1 ? "Изпрати" : "Напред";
          }
        }
      };

      var validateStep = function (stepIndex) {
        if (!bookingForm) return false;

        if (stepIndex === 0) {
          var serviceValue = bookingForm.querySelector(
            "input[name='serviceType']:checked"
          );
          if (!serviceValue) {
            setFeedback("Моля, избери услуга.");
            return false;
          }
          return true;
        }

        if (stepIndex === 1) {
          var dateInput = selectedDateInput;
          var timeInput = selectedTimeInput;
          if (isLoadingAvailability) {
            setFeedback("Изчакай да се заредят свободните часове.");
            return false;
          }
          if (!dateInput || !timeInput || !dateInput.value || !timeInput.value) {
            setFeedback("Моля, избери дата и час.");
            return false;
          }
          return true;
        }

        if (stepIndex === 2) {
          var fullNameInput = bookingForm.querySelector("input[name='fullName']");
          var phoneInput = bookingForm.querySelector("input[name='phone']");
          var emailInput = bookingForm.querySelector("input[name='email']");

          var isValid =
            fullNameInput &&
            phoneInput &&
            emailInput &&
            fullNameInput.value.trim() &&
            phoneInput.value.trim() &&
            emailInput.checkValidity();

          if (!isValid) {
            setFeedback("Попълни коректно име, телефон и имейл.");
            return false;
          }
          return true;
        }

        return true;
      };

      var resetFormState = function () {
        currentStep = 0;
        setSubmitting(false);
        if (bookingForm) {
          bookingForm.reset();
        }
        clearSelectedDateTime();
        availabilityByDay = {};
        availabilityDays = [];
        if (dayListEl) dayListEl.innerHTML = "";
        if (slotListEl) slotListEl.innerHTML = "";
        setSlotStatus("");
        setFeedback("");
        renderStep();
      };

      var openModal = function () {
        previousFocusedElement = document.activeElement;
        resetFormState();
        modal.hidden = false;
        modal.setAttribute("aria-hidden", "false");
        document.body.classList.add("modal-open");
        focusCurrentStepField();
      };

      var closeModal = function () {
        modal.hidden = true;
        modal.setAttribute("aria-hidden", "true");
        document.body.classList.remove("modal-open");
        if (
          previousFocusedElement &&
          typeof previousFocusedElement.focus === "function"
        ) {
          previousFocusedElement.focus();
        }
      };

      openTriggers.forEach(function (trigger) {
        trigger.addEventListener("click", function (event) {
          event.preventDefault();
          openModal();
        });
      });

      closeTriggers.forEach(function (trigger) {
        trigger.addEventListener("click", closeModal);
      });

      if (prevBtn) {
        prevBtn.addEventListener("click", function () {
          if (currentStep === 0) return;
          currentStep -= 1;
          renderStep();
          focusCurrentStepField();
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener("click", function () {
          var stepIsValid = validateStep(currentStep);
          if (!stepIsValid) return;

          if (currentStep < steps.length - 1) {
            currentStep += 1;
            renderStep();
            focusCurrentStepField();
            return;
          }

          if (bookingForm) {
            bookingForm.dispatchEvent(
              new Event("submit", { bubbles: true, cancelable: true })
            );
          }
        });
      }

      if (bookingForm) {
        bookingForm.addEventListener("input", updateDebugPreview);
        bookingForm.addEventListener("change", updateDebugPreview);

        bookingForm.addEventListener("submit", async function (event) {
          event.preventDefault();
          setFeedback("");

          if (!validateStep(steps.length - 1)) return;
          if (isSubmitting) return;

          var serviceInput = bookingForm.querySelector(
            "input[name='serviceType']:checked"
          );
          var dateInput = bookingForm.querySelector("input[name='date']");
          var timeInput = bookingForm.querySelector("input[name='time']");
          var fullNameInput = bookingForm.querySelector("input[name='fullName']");
          var phoneInput = bookingForm.querySelector("input[name='phone']");
          var emailInput = bookingForm.querySelector("input[name='email']");

          if (
            !serviceInput ||
            !dateInput ||
            !timeInput ||
            !fullNameInput ||
            !phoneInput ||
            !emailInput
          ) {
            setFeedback("Липсват данни от формата.");
            return;
          }

          var payload = buildBookingPayload();
          if (!payload) {
            setFeedback("Липсват данни от формата.");
            return;
          }

          var serviceLabel = payload.serviceLabel;
          var dateValue = dateInput.value;
          var timeValue = timeInput.value;
          var fullNameValue = fullNameInput.value.trim();
          var phoneValue = phoneInput.value.trim();
          var emailValue = emailInput.value.trim();

          setSubmitting(true);

          try {
            if (submitEndpoint) {
              var response = await fetch(submitEndpoint, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
              });

              var responseJson = null;
              try {
                responseJson = await response.json();
              } catch (jsonError) {
                responseJson = null;
              }

              if (!response.ok) {
                var serverError =
                  responseJson && responseJson.error
                    ? String(responseJson.error)
                    : "Submit endpoint returned " + response.status;
                throw new Error(serverError);
              }

              var bookingUidText =
                responseJson && responseJson.bookingUid
                  ? " №" + String(responseJson.bookingUid)
                  : "";
              var customEmailSent = !!(
                responseJson && responseJson.customEmailSent
              );
              var customEmailError =
                responseJson && responseJson.customEmailError
                  ? String(responseJson.customEmailError)
                  : "";

              if (customEmailSent) {
                setFeedback(
                  "Резервацията е потвърдена" +
                    bookingUidText +
                    ". Имейлът е изпратен успешно.",
                  "success"
                );
              } else if (customEmailError) {
                setFeedback(
                  "Резервацията е потвърдена" +
                    bookingUidText +
                    ", но имейлът не беше изпратен: " +
                    customEmailError
                );
              } else {
                setFeedback(
                  "Резервацията е потвърдена" + bookingUidText + ".",
                  "success"
                );
              }

              window.setTimeout(closeModal, 1600);
              return;
            }

            if (calBookingUrl) {
              var calUrl = new URL(calBookingUrl);
              calUrl.searchParams.set("name", fullNameValue);
              calUrl.searchParams.set("email", emailValue);
              calUrl.searchParams.set("phone", phoneValue);
              calUrl.searchParams.set(
                "notes",
                "Услуга: " +
                  serviceLabel +
                  "\nПредпочитана дата: " +
                  dateValue +
                  "\nПредпочитан час: " +
                  timeValue
              );
              calUrl.searchParams.set("service", serviceLabel);
              calUrl.searchParams.set("preferred_date", dateValue);
              calUrl.searchParams.set("preferred_time", timeValue);

              window.open(calUrl.toString(), "_blank", "noopener");
              setFeedback("Отваряме Cal.com за потвърждение на часа.", "success");
              window.setTimeout(closeModal, 600);
              return;
            }

            throw new Error("Booking config is missing");
          } catch (error) {
            setFeedback(error && error.message ? error.message : "Неуспешно изпращане.");
          } finally {
            setSubmitting(false);
          }
        });

        bookingForm.addEventListener("keydown", function (event) {
          if (event.key !== "Enter") return;
          if (currentStep === steps.length - 1) return;
          event.preventDefault();
          if (nextBtn) {
            nextBtn.click();
          }
        });
      }

      modal.addEventListener("click", function (event) {
        if (event.target === modal) {
          closeModal();
        }
      });

      document.addEventListener("keydown", function (event) {
        if (event.key === "Escape" && !modal.hidden) {
          closeModal();
        }
      });
    })();
  </script>
</body>
</html>

