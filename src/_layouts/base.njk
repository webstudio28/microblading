{% set i18nPageKey = pageI18nKey | default('index') %}
<!DOCTYPE html>
<html lang="{% if site and site.brand %}{{ site.brand.language }}{% else %}bg{% endif %}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% if not noAnimations %}<script>document.documentElement.classList.add("js-anim-ready");</script>{% endif %}
  <script>
    (function () {
      try {
        var stored = localStorage.getItem("valyamatovska-lang");
        if (stored === "en") {
          document.documentElement.lang = "en";
        }
      } catch (e) {}
    })();
  </script>
  <title
    data-i18n-title="meta.{{ i18nPageKey }}.title"
    data-i18n-title-bg="{% if title %}{{ title }}{% elif site and site.seo %}{{ site.seo.defaultTitle }}{% else %}Валя Матовска{% endif %}"
  >{% if title %}{{ title }}{% elif site and site.seo %}{{ site.seo.defaultTitle }}{% else %}Валя Матовска{% endif %}</title>
  <meta
    name="description"
    data-i18n-desc="meta.{{ i18nPageKey }}.description"
    data-i18n-desc-bg="{% if description %}{{ description }}{% elif site and site.seo %}{{ site.seo.defaultDescription }}{% endif %}"
    content="{% if description %}{{ description }}{% elif site and site.seo %}{{ site.seo.defaultDescription }}{% endif %}"
  >

  {% set _ogTitle %}{% if title %}{{ title }}{% elif site and site.seo %}{{ site.seo.defaultTitle }}{% else %}Валя Матовска{% endif %}{% endset %}
  {% set _ogDesc %}{% if description %}{{ description }}{% elif site and site.seo %}{{ site.seo.defaultDescription }}{% endif %}{% endset %}
  {% set _ogImg = ogImage | default(site.seo.defaultOgImage) | default('/assets/images/hero-img2.jpeg') %}
  {% set _siteUrl = site.seo.siteUrl | default('https://www.valyamatovska.bg') %}
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Валя Матовска">
  <meta property="og:url" content="{{ _siteUrl }}{{ page.url | url }}">
  <meta property="og:title" content="{{ _ogTitle }}">
  <meta property="og:description" content="{{ _ogDesc }}">
  <meta property="og:image" content="{{ _siteUrl }}{{ _ogImg }}">
  <meta name="twitter:card" content="{% if site and site.seo and site.seo.twitterCard %}{{ site.seo.twitterCard }}{% else %}summary_large_image{% endif %}">
  <meta name="twitter:title" content="{{ _ogTitle }}">
  <meta name="twitter:description" content="{{ _ogDesc }}">
  <meta name="twitter:image" content="{{ _siteUrl }}{{ _ogImg }}">

  {% if site and site.seo and site.seo.siteUrl %}
  <link rel="canonical" href="{{ site.seo.siteUrl }}{{ page.url | url }}">
  <link rel="sitemap" type="application/xml" title="Sitemap" href="{{ '/sitemap.xml' | url }}">
  {% endif %}

  <meta name="google-site-verification" content="WyI8FfZunhL-v0KaWlT4JGBN7TB4EfZMiMm157B5ku4">

  <meta name="theme-color" content="{% if site and site.colors %}{{ site.colors.primary }}{% else %}#0f172a{% endif %}">

  <link rel="icon" href="{{ '/favicon.ico' | url }}" sizes="any">
  <link rel="icon" href="{{ '/favicon.png' | url }}" type="image/png">
  <link rel="apple-touch-icon" href="{{ '/favicon.png' | url }}">

  <style>
    :root{
      --color-brand-primary: {% if site and site.colors %}{{ site.colors.primary }}{% else %}#2563eb{% endif %};
      --color-brand-secondary: {% if site and site.colors %}{{ site.colors.secondary }}{% else %}#64748b{% endif %};
      --color-brand-accent: {% if site and site.colors %}{{ site.colors.accent }}{% else %}#f59e0b{% endif %};
    }
  </style>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat+Alternates:wght@200;300;400;500&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/assets/css/styles.css' | url }}">
  <script>window.__I18N__ = { en: {{ i18n.en | dump | safe }} };</script>
  <script src="{{ '/assets/js/i18n.js' | url }}" defer></script>
  <script src="{{ '/assets/js/strip-scroll.js' | url }}" defer></script>
  <script src="{{ '/assets/js/clients-strip.js' | url }}" defer></script>
  {% if not noAnimations %}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
  <script src="{{ '/assets/js/animations.js' | url }}" defer></script>
  {% endif %}
  <script>
    // iOS Safari does not render a video thumbnail unless the element has been
    // seeked to a non-zero time. This forces the first frame to be decoded for
    // every muted+playsinline video (gallery bubbles, about section, etc.).
    (function () {
      function fixVideoThumb(video) {
        if (video.currentTime === 0) {
          video.currentTime = 0.001;
        }
      }
      function applyToAll() {
        document.querySelectorAll("video[muted][playsinline]").forEach(function (v) {
          if (v.readyState >= 1) {
            fixVideoThumb(v);
          } else {
            v.addEventListener("loadedmetadata", function () { fixVideoThumb(v); }, { once: true });
          }
        });
      }
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", applyToAll);
      } else {
        applyToAll();
      }
    })();
  </script>
</head>
<body>
  {# Full-page texture overlay — sits above gradient, below all content #}
  <div class="site-bg-overlay" aria-hidden="true"></div>

  <div class="relative z-10">
    {% include "header.njk" %}
    {{ content | safe }}
    {% if not hideFooter %}
    {% include "footer.njk" %}
    {% endif %}
  </div>

  {% include "testimonial-read-modal.njk" %}

  <script>
    (function () {
      var headerSurface = document.querySelector(".js-header-surface");
      if (!headerSurface) return;

      var onScroll = function () {
        if (window.scrollY > 18) {
          headerSurface.classList.add("is-glassy");
        } else {
          headerSurface.classList.remove("is-glassy");
        }
      };

      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });
    })();

    (function () {
      var toggle = document.getElementById("mobile-menu-toggle");
      var panel = document.getElementById("mobile-menu-panel");
      var backdrop = document.getElementById("mobile-menu-backdrop");
      var closeBtn = document.getElementById("mobile-menu-close");
      if (!toggle || !panel || !backdrop) return;

      var mobileLinks = panel.querySelectorAll(".mobile-menu-link");
      var isOpen = false;
      var closeTimer = null;

      var openMenu = function () {
        if (closeTimer) {
          window.clearTimeout(closeTimer);
          closeTimer = null;
        }
        isOpen = true;
        toggle.classList.add("is-active");
        toggle.setAttribute("aria-expanded", "true");
        toggle.setAttribute("aria-label", "Затвори меню");
        panel.hidden = false;
        backdrop.hidden = false;
        panel.setAttribute("aria-hidden", "false");
        backdrop.setAttribute("aria-hidden", "false");
        document.body.classList.add("modal-open");

        requestAnimationFrame(function () {
          panel.classList.add("is-open");
          backdrop.classList.add("is-open");
        });
      };

      var closeMenu = function () {
        if (!isOpen) return;
        isOpen = false;
        toggle.classList.remove("is-active");
        toggle.setAttribute("aria-expanded", "false");
        toggle.setAttribute("aria-label", "Отвори меню");
        panel.classList.remove("is-open");
        backdrop.classList.remove("is-open");
        panel.setAttribute("aria-hidden", "true");
        backdrop.setAttribute("aria-hidden", "true");
        document.body.classList.remove("modal-open");

        closeTimer = window.setTimeout(function () {
          panel.hidden = true;
          backdrop.hidden = true;
          closeTimer = null;
        }, 290);
      };

      toggle.addEventListener("click", function () {
        if (isOpen) closeMenu();
        else openMenu();
      });

      if (closeBtn) closeBtn.addEventListener("click", closeMenu);
      backdrop.addEventListener("click", closeMenu);
      mobileLinks.forEach(function (link) {
        link.addEventListener("click", closeMenu);
      });

      document.addEventListener("keydown", function (event) {
        if (event.key === "Escape" && isOpen) closeMenu();
      });
    })();

  </script>
</body>
</html>

