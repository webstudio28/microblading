        </div>

        {# Image column — desktop #}
        <div class="order-2 hidden justify-center md:flex lg:justify-end">
          <div class="hero-photo-wrap">
            <picture>
              <source media="(max-width: 767px)" srcset="{{ '/assets/images/hero-img-mobile.jpg' | url }}">
              <img
                src="{{ '/assets/images/hero-img.jpeg' | url }}"
                alt="Ламиниране на вежди и мигли — Валя Матовска"
                class="hero-photo"
                width="460" height="540"
                loading="eager"
              >
            </picture>
          </div>
        </div>

        {# Mobile CTAs #}
        <div class="order-3 mt-0.5 flex w-full min-w-0 flex-row flex-nowrap gap-2 md:hidden">
          <a href="{{ bookingUrl }}" class="btn-primary min-w-0 flex-1 px-4 py-2 text-sm" target="_blank" rel="noopener noreferrer">
            Запази час
          </a>
          <a href="#lam-gallery" class="btn-secondary min-w-0 flex-1 px-4 py-2 text-sm">
            Виж резултати
          </a>
        </div>

      </div>
    </div>
  </section>


  {# ═══════════════════════════════════════════════
     2. TRUST BAR
  ═══════════════════════════════════════════════ #}
  <div class="bg-white/70 border-y border-[rgba(201,169,138,0.3)]">
    <div class="container-custom">
      <ul class="flex flex-col items-center gap-4 py-6 text-center sm:flex-row sm:justify-center sm:gap-0 sm:divide-x sm:divide-[rgba(201,169,138,0.4)]" aria-label="Защо Валя Матовска">
        <li class="flex items-center gap-2.5 px-6 text-sm font-medium text-ink sm:text-base">
          <svg class="h-5 w-5 shrink-0 text-[#c9a98a]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <span>Вежди и мигли — в едно</span>
