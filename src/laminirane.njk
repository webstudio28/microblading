        <h2 id="lam-testimonials-heading" class="mb-title mt-2 text-center" data-i18n="pages.laminirane.testimonials.title">
          Какво казват клиентите
        </h2>
        <p class="site-lead mx-auto mt-4 max-w-2xl text-center text-muted" data-i18n="pages.laminirane.testimonials.lead">
          Всички отзиви са 100% автентични — от реални клиенти.
        </p>
      </header>
    </div>

    <div class="testimonials-strip-wrapper">
      <div class="testimonials-strip" aria-label="Отзиви от клиенти — ламиниране">
        <div class="testimonials-strip-set">
          {% for item in lamTestimonials %}
          <article class="testimonial-card" data-testimonial-index="{{ loop.index0 }}">
            <div class="testimonial-card__stars" aria-hidden="true">
              <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
            </div>
            <p class="testimonial-card__quote" data-i18n="home.testimonials.items.{{ loop.index0 }}.quote">{{ item.quote }}</p>
            <button
              type="button"
              class="testimonial-card__expand"
              hidden
              data-testimonial-open
              data-testimonial-index="{{ loop.index0 }}"
            >
              Виж целия отзив
            </button>
            <p class="testimonial-card__name">– <span data-i18n="home.testimonials.items.{{ loop.index0 }}.name">{{ item.name }}</span></p>
          </article>
          {% endfor %}
        </div>
        <div class="testimonials-strip-set" aria-hidden="true">
          {% for item in lamTestimonials %}
          <article class="testimonial-card" data-testimonial-index="{{ loop.index0 }}">
            <div class="testimonial-card__stars" aria-hidden="true">
              <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
            </div>
            <p class="testimonial-card__quote">{{ item.quote }}</p>
            <button
              type="button"
              class="testimonial-card__expand"
              hidden
              data-testimonial-open
              data-testimonial-index="{{ loop.index0 }}"
            >
              Виж целия отзив
            </button>
            <p class="testimonial-card__name">– {{ item.name }}</p>
          </article>
          {% endfor %}
        </div>
      </div>
