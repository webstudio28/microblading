  ═══════════════════════════════════════════════ #}
  <section class="hero-section section-padding" id="lam-hero" aria-labelledby="lam-hero-heading">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-16 items-center">

