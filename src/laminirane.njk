  {# ═══════════════════════════════════════════════
     7. GALLERY
  ═══════════════════════════════════════════════ #}
  {% if lb.gallery and lb.gallery.length %}
  <section
    id="lam-gallery"
    class="mb-section section-padding pb-8 md:pb-12 pt-10 md:pt-14"
    aria-labelledby="lp-lam-gallery-label"
  >
    <div class="mb-bubbles-wrap" data-lp-lam-bubbles-wrap>
      <div class="container-custom">
        <div class="mb-bubbles-head">
          <p class="mb-bubbles-label" id="lp-lam-gallery-label" data-i18n="pages.laminirane.gallery.label">Галерия</p>
          <div class="mb-bubbles-nav" aria-hidden="true">
            <button type="button" class="mb-bubbles-arrow mb-bubbles-arrow--prev" data-lp-lam-prev aria-label="Предишна снимка">
              <svg class="mb-arrow-icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="21 8 12 16 21 24" vector-effect="non-scaling-stroke"/></svg>
            </button>
            <button type="button" class="mb-bubbles-arrow mb-bubbles-arrow--next" data-lp-lam-next aria-label="Следваща снимка">
              <svg class="mb-arrow-icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="11 8 20 16 11 24" vector-effect="non-scaling-stroke"/></svg>
            </button>
          </div>
        </div>
      </div>

      <div class="mb-bubbles" role="list" data-lp-lam-bubbles aria-labelledby="lp-lam-gallery-label">
        {% for item in lb.gallery %}
        <figure
          class="mb-bubble{% if item.src | isVideoPath %} mb-bubble--video{% endif %}"
          role="listitem"
          data-lp-lam-gallery-trigger
          data-lp-lam-gallery-index="{{ loop.index0 }}"
        >
          {% if item.src | isVideoPath %}
          <video
            src="{{ item.src | url }}"
            data-lp-lam-gallery-item
            data-lp-lam-gallery-index="{{ loop.index0 }}"
            muted playsinline loop preload="metadata"
            aria-label="{{ item.alt | default('Ламиниране — видео') }}"
          ></video>
          <span class="mb-bubble__video-badge" aria-hidden="true">
            <svg viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="28" cy="28" r="26" fill="rgba(255,255,255,0.92)" stroke="rgba(44,26,14,0.1)" stroke-width="1"/>
              <path fill="#3a2415" d="M23 17v22l18-11-18-11Z"/>
            </svg>
          </span>
          {% else %}
          <img
            src="{{ item.src | url }}"
            alt="{{ item.alt | default('Ламиниране — снимка') }}"
            data-lp-lam-gallery-item
            data-lp-lam-gallery-index="{{ loop.index0 }}"
            loading="lazy"
            decoding="async"
          />
          {% endif %}
        </figure>
        {% endfor %}
      </div>
    </div>

    <div
      id="lp-lam-gallery-modal"
      class="mb-gallery-modal"
      role="dialog"
      aria-modal="true"
      aria-hidden="true"
      aria-label="Галерия ламиниране"
      hidden
    >
      <div class="mb-gallery-modal__backdrop" data-lp-lam-gallery-close></div>
      <div class="mb-gallery-modal__panel" role="document">
        <button type="button" class="mb-gallery-modal__close" data-lp-lam-gallery-close aria-label="Затвори галерията">&times;</button>
        <button type="button" class="mb-gallery-modal__arrow mb-gallery-modal__arrow--prev" data-lp-lam-gallery-prev aria-label="Предишна снимка">
          <svg class="mb-arrow-icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="21 8 12 16 21 24" vector-effect="non-scaling-stroke"/></svg>
        </button>
        <div class="mb-gallery-modal__stage" data-lp-lam-gallery-stage>
          <div class="mb-gallery-modal__clip">
            <img class="mb-gallery-modal__image" data-lp-lam-gallery-image src="" alt="" />
            <video class="mb-gallery-modal__image" data-lp-lam-gallery-video playsinline muted loop hidden></video>
          </div>
        </div>
        <button type="button" class="mb-gallery-modal__arrow mb-gallery-modal__arrow--next" data-lp-lam-gallery-next aria-label="Следваща снимка">
          <svg class="mb-arrow-icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="11 8 20 16 11 24" vector-effect="non-scaling-stroke"/></svg>
        </button>
      </div>
    </div>
  </section>
  {% endif %}


  {# ═══════════════════════════════════════════════
     8. FAQ
  ═══════════════════════════════════════════════ #}
  <section
    id="lam-faq"
    class="mb-section section-padding bg-white/70"
    aria-labelledby="lam-faq-heading"
  >
    <div class="container-custom">
      <header class="mb-header mx-auto mb-8 text-center md:mb-10">
        <span class="mb-eyebrow justify-center" data-i18n="pages.laminirane.faq.eyebrow">Въпроси и отговори</span>
        <h2 id="lam-faq-heading" class="mb-title mt-2 text-center" data-i18n="pages.laminirane.faq.title">
          Често задавани въпроси
        </h2>
      </header>

      <div class="faq-stack w-full max-w-3xl mx-auto" data-lp-lam-faq-accordion>

        <details class="faq-details" name="lam-lp-faq">
          <summary class="faq-details__summary">
            <span class="faq-details__question" data-i18n="pages.laminirane.faq.items.0.question">Каква е разликата между ламиниране на вежди и мигли?</span>
            <span class="faq-details__chevron" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" class="faq-details__chevron-svg"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </summary>
          <div class="faq-details__content"><div class="faq-details__inner">
            <p class="faq-details__answer" data-i18n="pages.laminirane.faq.items.0.answer">Ламинирането на вежди оформя и фиксира косъмчетата в желана посока за по-плътен и подреден вид. Ламинирането на мигли ги извива и подхранва за по-отворен поглед без спирала. Двете процедури са независими и могат да се правят самостоятелно или заедно.</p>
          </div></div>
        </details>

        <details class="faq-details" name="lam-lp-faq">
          <summary class="faq-details__summary">
            <span class="faq-details__question" data-i18n="pages.laminirane.faq.items.1.question">Болезнено ли е ламинирането?</span>
            <span class="faq-details__chevron" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" class="faq-details__chevron-svg"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </summary>
          <div class="faq-details__content"><div class="faq-details__inner">
            <p class="faq-details__answer" data-i18n="pages.laminirane.faq.items.1.answer">Не, процедурата е напълно безболезнена и много релаксираща. Повечето клиенти се отпускат по средата. Ползвам висококачествени продукти, щадящи за кожата и косъма.</p>
          </div></div>
        </details>

        <details class="faq-details" name="lam-lp-faq">
          <summary class="faq-details__summary">
            <span class="faq-details__question" data-i18n="pages.laminirane.faq.items.2.question">Колко дълго издържа резултатът?</span>
            <span class="faq-details__chevron" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" class="faq-details__chevron-svg"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </summary>
          <div class="faq-details__content"><div class="faq-details__inner">
            <p class="faq-details__answer" data-i18n="pages.laminirane.faq.items.2.answer">Ламинирането на вежди трае средно 4–6 седмици, а ламинирането на мигли — 6–8 седмици в зависимост от естествения цикъл на растеж. С правилна грижа у дома можеш да удължиш ефекта.</p>
          </div></div>
        </details>

        <details class="faq-details" name="lam-lp-faq">
          <summary class="faq-details__summary">
            <span class="faq-details__question" data-i18n="pages.laminirane.faq.items.3.question">Мога ли да се мокря след процедурата?</span>
            <span class="faq-details__chevron" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" class="faq-details__chevron-svg"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </summary>
          <div class="faq-details__content"><div class="faq-details__inner">
            <p class="faq-details__answer" data-i18n="pages.laminirane.faq.items.3.answer">Препоръчително е зоната да остане суха около 24–48 часа след процедурата. След това можеш да се мокриш нормално — включително плуване и душ. Ще получиш писмени насоки за грижа след всяка процедура.</p>
          </div></div>
        </details>

        <details class="faq-details" name="lam-lp-faq">
          <summary class="faq-details__summary">
            <span class="faq-details__question" data-i18n="pages.laminirane.faq.items.4.question">Може ли да се комбинира ламинирането с боядисване?</span>
            <span class="faq-details__chevron" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" class="faq-details__chevron-svg"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </summary>
          <div class="faq-details__content"><div class="faq-details__inner">
            <p class="faq-details__answer" data-i18n="pages.laminirane.faq.items.4.answer">Да! Ламинирането на вежди може да се комбинира с боядисване на веждите за по-изразен, наситен резултат. Ламинирането на мигли — с оцветяване за допълнителен акцент. Обсъждаме заедно кое е най-подходящо за теб.</p>
          </div></div>
        </details>

        <details class="faq-details" name="lam-lp-faq">
          <summary class="faq-details__summary">
            <span class="faq-details__question" data-i18n="pages.laminirane.faq.items.5.question">За кого е подходящо ламинирането?</span>
            <span class="faq-details__chevron" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" class="faq-details__chevron-svg"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </summary>
          <div class="faq-details__content"><div class="faq-details__inner">
            <p class="faq-details__answer" data-i18n="pages.laminirane.faq.items.5.answer">Ламинирането е подходящо за почти всеки. За вежди — особено за непокорни, редки или с неравномерен растеж. За мигли — за прави, редки или слабо извити мигли. На консултацията преценяваме заедно кой вид е най-подходящ за твоя тип.</p>
          </div></div>
        </details>

      </div>
    </div>
  </section>


