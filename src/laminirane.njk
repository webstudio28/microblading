            </p>
            <p class="mb-lead mt-5 text-white/90" data-i18n="pages.laminirane.about.body2">
              Всяка процедура при мен е съобразена с индивидуалната посока на косъма и чертите на лицето, с цел резултат, който изглежда свеж, лек и поддържан в ежедневието без усилие.
            </p>
          </div>

          <button
            type="button"
            id="lp-lam-about-toggle"
            class="mt-6 self-start font-['Montserrat_Alternates'] text-sm font-medium text-white underline underline-offset-4 transition-opacity hover:opacity-70 md:hidden"
            aria-expanded="false"
            aria-controls="lp-lam-about-more"
            data-i18n="pages.laminirane.about.toggle"
          >
            Виж повече за мен
          </button>
        </div>
      </div>
    </div>
  </section>
  <script>
    (function () {
      var btn = document.getElementById("lp-lam-about-toggle");
      var more = document.getElementById("lp-lam-about-more");
      if (!btn || !more) return;
      btn.addEventListener("click", function () {
        var expanded = btn.getAttribute("aria-expanded") === "true";
        var lang = window.ValyamatovskaI18n ? window.ValyamatovskaI18n.getLang() : "bg";
        if (expanded) {
          more.classList.add("hidden");
          btn.setAttribute("aria-expanded", "false");
          btn.setAttribute("data-i18n-bg", "Виж повече за мен");
          btn.textContent = lang === "en" ? "Learn more about me" : "Виж повече за мен";
        } else {
          more.classList.remove("hidden");
          btn.setAttribute("aria-expanded", "true");
          btn.setAttribute("data-i18n-bg", "Виж по-малко");
          btn.textContent = lang === "en" ? "See less" : "Виж по-малко";
        }
      });
    })();
  </script>


  {# ═══════════════════════════════════════════════
