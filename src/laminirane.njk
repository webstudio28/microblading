          <h1 id="lam-hero-heading" class="font-mak text-[2.35rem] leading-[1.12] text-ink md:text-6xl md:leading-[1.1] xl:text-[4.25rem] xl:leading-[1.08]" data-i18n="pages.laminirane.hero.headline">
